      <div class="text-center mb-14">
        <p style="color:#C17B50; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:0.5rem;">🐾 🐾 🐾</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.25rem,4vw,3.25rem); font-weight:700; color:#3D2B1F; margin-bottom:0.75rem;">Pawsitively Reviewed</h2>
        <p style="color:#5C4033; max-width:440px; margin:0 auto; font-family:'Inter',system-ui,sans-serif;">Real words from real pet parents who trust us every time.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((t, i) => {
          const rots = ['1.5deg', '-1.5deg', '1deg'];
          const rot = rots[i % rots.length];
          return (
            <div style={`background:#F2EAD8; border:1px solid #e0d4bc; border-radius:14px; padding:2rem 1.75rem 1.75rem; position:relative; transform:rotate(${rot}); box-shadow:0 2px 12px rgba(61,43,31,0.09); transition:transform 0.25s, box-shadow 0.25s;`} class="hover:shadow-md" onmouseover={`this.style.transform='rotate(0deg)'`} onmouseout={`this.style.transform='rotate(${rot})'`}>
              <div class="tape-strip"></div>
              <div style="font-family:'Cormorant Garamond',Georgia,serif; font-size:4rem; line-height:1; color:#6B8F71; opacity:0.35; margin-bottom:-1rem; user-select:none;">"</div>
              <div style="display:flex; gap:2px; color:#C17B50; font-size:1rem; margin-bottom:0.75rem;" aria-label={`${t.stars} out of 5 stars`}>
                {'★'.repeat(t.stars)}
