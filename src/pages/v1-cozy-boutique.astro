            </div>
            <div style="display:flex; flex-direction:column; gap:0.4rem;">
              <label for="v1-size" style="font-size:0.8rem; font-weight:600; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif;">Size</label>
              <select id="v1-size" name="size" style="border-radius:8px; border:1.5px solid #d4c9b5; padding:0.7rem 1rem; font-size:0.875rem; background:#fff; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif; width:100%; box-sizing:border-box;">
                <option value="">Select size…</option>
                <option value="small">Small (under 25 lbs)</option>
                <option value="medium">Medium (25–55 lbs)</option>
                <option value="large">Large (55–85 lbs)</option>
                <option value="xlarge">XL (85+ lbs)</option>
              </select>
            </div>
            <div style="display:flex; flex-direction:column; gap:0.4rem;">
              <label for="v1-service" style="font-size:0.8rem; font-weight:600; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif;">Service <span style="color:#C17B50;">*</span></label>
              <select id="v1-service" name="service" required style="border-radius:8px; border:1.5px solid #d4c9b5; padding:0.7rem 1rem; font-size:0.875rem; background:#fff; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif; width:100%; box-sizing:border-box;">
