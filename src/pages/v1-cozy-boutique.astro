            <div style="display:flex; flex-direction:column; gap:0.4rem;">
              <label for="v1-date" style="font-size:0.8rem; font-weight:600; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif;">Drop-off Date <span style="color:#C17B50;">*</span></label>
              <input id="v1-date" name="date" type="date" required style="border-radius:8px; border:1.5px solid #d4c9b5; padding:0.7rem 1rem; font-size:0.875rem; background:#fff; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif; width:100%; box-sizing:border-box;" />
            </div>
            <div style="display:flex; flex-direction:column; gap:0.4rem;">
              <label for="v1-end-date" style="font-size:0.8rem; font-weight:600; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif;">Pick-up Date <span style="color:#C17B50;">*</span></label>
              <input id="v1-end-date" name="endDate" type="date" required style="border-radius:8px; border:1.5px solid #d4c9b5; padding:0.7rem 1rem; font-size:0.875rem; background:#fff; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif; width:100%; box-sizing:border-box;" />
            </div>
          </div>
          <div style="display:flex; flex-direction:column; gap:0.4rem;">
            <label for="v1-notes" style="font-size:0.8rem; font-weight:600; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif;">Special Needs / Notes</label>
            <textarea id="v1-notes" name="notes" rows="4" placeholder="Dietary needs, medications, behavioral notes, anything we should know…" style="border-radius:8px; border:1.5px solid #d4c9b5; padding:0.7rem 1rem; font-size:0.875rem; background:#fff; color:#3D2B1F; font-family:'Inter',system-ui,sans-serif; width:100%; box-sizing:border-box; resize:vertical;"></textarea>
          </div>
          <button type="submit" class="btn-sage" style="width:100%; text-align:center; padding:1rem; font-size:1rem; font-weight:700; border:none; cursor:pointer;">
            Request Reservation
          </button>
        </form>
        <div id="v1-booking-success" style="display:none; text-align:center; padding:3rem 1rem;">
          <div style="font-size:3.5rem; margin-bottom:1rem;">🐾</div>
          <h3 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:1.75rem; font-weight:700; color:#3D2B1F; margin-bottom:0.5rem;">We'll be in touch!</h3>
          <p style="color:#5C4033; font-family:'Inter',system-ui,sans-serif;">Thanks! We'll contact you within 24 hours to confirm your reservation.</p>
        </div>
      </div>
      <style>
        @media (max-width: 580px) {
          .v1-form-grid-2, .v1-form-grid-3 { grid-template-columns: 1fr !important; }
