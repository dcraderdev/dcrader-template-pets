---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v1/business';
import { services, packages } from '../data/v1/services';
import { gallery } from '../data/v1/gallery';
---
<BaseLayout title={`${business.name} — ${business.tagline}`} description={business.description}>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v1-banner" style="background:#6B8F71;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative">
    <span>🐾 New clients: First day of daycare FREE with overnight booking · Limited spots · (415) 882-3047</span>
    <button onclick="document.getElementById('v1-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    :root {
      --cream: #FAF6EF;
      --card: #F2EAD8;
      --sage: #6B8F71;
      --terra: #C17B50;
      --brown-dark: #3D2B1F;
      --brown-body: #5C4033;
      --muted: #9C7B6C;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--cream); font-family: 'Lato', sans-serif; color: var(--brown-body); }
    .font-playfair { font-family: 'Playfair Display', Georgia, serif; }
    .hero-bg {
      background-image: linear-gradient(rgba(61,43,31,0.42), rgba(61,43,31,0.52)),
        url('https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1600&h=900&fit=crop&q=80');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }
    .wave-divider { overflow: hidden; line-height: 0; }
    .btn-sage { background: #6B8F71; color: #fff; border-radius: 9999px; padding: 0.75rem 2rem; font-weight: 700; transition: background 0.2s; display: inline-block; }
    .btn-sage:hover { background: #557260; }
    .btn-terra { background: #C17B50; color: #fff; border-radius: 9999px; padding: 0.75rem 2rem; font-weight: 700; transition: background 0.2s; display: inline-block; }
    .btn-terra:hover { background: #a56540; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #6B8F71; outline-offset: 2px; }
    @keyframes pawBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
    section[id] { scroll-margin-top: 5rem; }
    @media (max-width: 768px) { .hero-bg { background-attachment: scroll; } }
  </style>

  <!-- NAV -->
  <nav style="background:#3D2B1F;" class="sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl">🐾</span>
        <span class="font-playfair text-xl font-bold text-white">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="#services" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Services</a>
        <a href="#pricing" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Pricing</a>
        <a href="#gallery" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Gallery</a>
        <a href="#team" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Team</a>
        <a href="#contact" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Contact</a>
        <a href="#booking" class="btn-terra text-sm py-2 px-5">Book Now</a>
      </div>
      <button id="v1-menu-btn" class="md:hidden text-white text-2xl" aria-label="Open menu">☰</button>
    </div>
    <div id="v1-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3">
      <a href="#services" class="text-[#F2EAD8] text-sm font-semibold">Services</a>
      <a href="#pricing" class="text-[#F2EAD8] text-sm font-semibold">Pricing</a>
      <a href="#gallery" class="text-[#F2EAD8] text-sm font-semibold">Gallery</a>
      <a href="#team" class="text-[#F2EAD8] text-sm font-semibold">Team</a>
      <a href="#contact" class="text-[#F2EAD8] text-sm font-semibold">Contact</a>
      <a href="#booking" class="btn-terra text-sm py-2 px-5 text-center">Book Now</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero" class="hero-bg min-h-screen flex items-center justify-center text-center px-4">
    <div class="max-w-3xl mx-auto">
      <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-4">Est. {business.founded} · {business.neighborhood}, San Francisco</p>
      <h1 class="font-playfair text-5xl md:text-7xl font-bold text-white leading-tight mb-6">
        Where Every Dog<br/><em>Stays Like a Guest</em>
      </h1>
      <p class="text-white/90 text-lg md:text-xl mb-10 max-w-xl mx-auto leading-relaxed">{business.tagline}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#booking" class="btn-terra text-base px-8 py-4">Reserve a Stay</a>
        <a href="#services" class="border-2 border-white text-white rounded-full px-8 py-4 font-bold hover:bg-white hover:text-[#3D2B1F] transition-all">Explore Services</a>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6 text-white/80 text-sm">
        <span>⭐ 4.9 (312 reviews)</span>
        <span>🔒 Licensed & Insured</span>
        <span>📸 Photo updates twice daily</span>
        <span>🏥 Fear Free Certified</span>
      </div>
    </div>
  </section>

  <!-- WAVE DIVIDER -->
  <div class="wave-divider bg-[#3D2B1F]">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 L1440,60 L1440,30 C1080,0 360,60 0,30 Z" fill="#FAF6EF"/>
    </svg>
  </div>

  <!-- SERVICES -->
  <section id="services" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">What We Offer</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">Our Services</h2>
        <p class="text-[#5C4033] max-w-xl mx-auto text-lg">Tailored care for every dog, every visit. Because your pet deserves more than the basics.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((s) => (
          <div class="rounded-2xl p-6 flex flex-col gap-3 shadow-sm hover:shadow-md transition-shadow" style="background:#F2EAD8; border:1px solid #e0d4bc;">
            <div class="text-4xl">{s.icon}</div>
            <h3 class="font-playfair text-xl font-bold text-[#3D2B1F]">{s.name}</h3>
            <p class="text-sm text-[#5C4033] leading-relaxed flex-grow">{s.description}</p>
            <p class="font-bold text-[#C17B50] text-lg">{s.price}</p>
            <ul class="space-y-1">
              {s.highlights.map((h) => (
                <li class="text-xs text-[#5C4033] flex items-center gap-2">
                  <span class="text-[#6B8F71] font-bold">✓</span> {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HEALTH & REQUIREMENTS -->
  <section class="py-16 px-4" style="background:#FAF6EF;">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-2xl p-8 md:p-10" style="background:#F2EAD8; border:2px solid #6B8F71;">
        <h2 class="font-playfair text-3xl md:text-4xl font-bold text-[#3D2B1F] mb-2">Health & Requirements</h2>
        <p class="text-[#9C7B6C] mb-8 text-sm">For the safety and wellbeing of every dog in our care.</p>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-playfair text-lg font-bold text-[#3D2B1F] mb-2">💉 Vaccination Requirements</h3>
            <p class="text-sm text-[#5C4033] leading-relaxed">All breeds must have current <strong>Rabies</strong>, <strong>Bordetella</strong> (within 6 months), and <strong>DHPP/DA2PP</strong>. Records required before first visit.</p>
          </div>
          <div>
            <h3 class="font-playfair text-lg font-bold text-[#3D2B1F] mb-2">🤝 Temperament Assessment</h3>
            <p class="text-sm text-[#5C4033] leading-relaxed">New dogs require a free 30-minute meet &amp; greet before their first booking. We want everyone to feel at home.</p>
          </div>
          <div>
            <h3 class="font-playfair text-lg font-bold text-[#3D2B1F] mb-2">🛡️ Health Guarantee</h3>
            <p class="text-sm text-[#5C4033] leading-relaxed">Dogs must be flea/tick free, not in heat, and free of any contagious illness on the day of arrival.</p>
          </div>
          <div>
            <h3 class="font-playfair text-lg font-bold text-[#3D2B1F] mb-2">🚨 Emergency Protocol</h3>
            <p class="text-sm text-[#5C4033] leading-relaxed">24/7 vet partner is two blocks away. You are notified immediately of any incident — no exceptions, no delays.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WAVE DIVIDER CREAM→CARD -->
  <div class="wave-divider" style="background:#F2EAD8;">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,0 C360,60 1080,0 1440,60 L1440,0 L0,0 Z" fill="#FAF6EF"/>
    </svg>
  </div>

  <!-- PRICING -->
  <section id="pricing" class="py-20 px-4" style="background:#F2EAD8;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Packages</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">Choose Your Stay</h2>
        <p class="text-[#5C4033] max-w-xl mx-auto">Bundle and save — every package includes our standard of attentive, personal care.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {packages.map((pkg) => (
          <div class={`rounded-2xl p-8 flex flex-col gap-4 relative ${pkg.featured ? 'shadow-2xl scale-105' : 'shadow-sm'}`}
               style={pkg.featured ? 'background:#6B8F71; color:#fff;' : 'background:#FAF6EF; border:1px solid #e0d4bc;'}>
            {pkg.featured && <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#C17B50] text-white text-xs font-bold py-1 px-4 rounded-full">Most Popular</div>}
            <div>
              <h3 class="font-playfair text-2xl font-bold mb-1" style={pkg.featured ? 'color:#fff' : 'color:#3D2B1F'}>{pkg.name}</h3>
              <p class="text-sm" style={pkg.featured ? 'color:rgba(255,255,255,0.8)' : 'color:#9C7B6C'}>{pkg.period}</p>
            </div>
            <div class="text-4xl font-bold" style={pkg.featured ? 'color:#fff' : 'color:#C17B50'}>{pkg.price}</div>
            <p class="text-sm" style={pkg.featured ? 'color:rgba(255,255,255,0.85)' : 'color:#5C4033'}>{pkg.description}</p>
            <ul class="space-y-2 flex-grow">
              {pkg.features.map((f) => (
                <li class="text-sm flex items-start gap-2" style={pkg.featured ? 'color:rgba(255,255,255,0.9)' : 'color:#5C4033'}>
                  <span style={pkg.featured ? 'color:#F2EAD8' : 'color:#6B8F71'} class="font-bold mt-0.5">✓</span> {f}
                </li>
              ))}
            </ul>
            <a href="#booking" class={`text-center rounded-full py-3 px-6 font-bold text-sm transition-all mt-2 ${pkg.featured ? 'bg-white text-[#6B8F71] hover:bg-[#F2EAD8]' : 'btn-sage'}`}>
              Book This Package
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WAVE DIVIDER CARD→CREAM -->
  <div class="wave-divider" style="background:#FAF6EF;">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block;width:100%;height:60px;">
      <path d="M0,60 C360,0 1080,60 1440,0 L1440,0 L0,0 Z" fill="#F2EAD8"/>
    </svg>
  </div>

  <!-- GALLERY -->
  <section id="gallery" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Life at Paws & Pine</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">The Gallery</h2>
        <p class="text-[#5C4033] max-w-xl mx-auto">A glimpse of everyday joy — real guests, real moments.</p>
      </div>
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {gallery.map((img, i) => (
          <div class="break-inside-avoid group relative overflow-hidden rounded-2xl shadow-sm hover:shadow-md transition-shadow">
            <img src={img.url} alt={img.alt} loading="lazy" class="w-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <p class="text-white text-sm font-semibold">{img.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 px-4" style="background:#FAF6EF;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Getting Started</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F]">How It Works</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-playfair text-white" style="background:#6B8F71;">1</div>
          <h3 class="font-playfair text-xl font-bold text-[#3D2B1F]">Apply Online</h3>
          <p class="text-sm text-[#5C4033] leading-relaxed">Fill out our quick new-client form. Takes about 3 minutes and tells us everything we need to know about your pup.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-playfair text-white" style="background:#C17B50;">2</div>
          <h3 class="font-playfair text-xl font-bold text-[#3D2B1F]">Free Meet &amp; Greet</h3>
          <p class="text-sm text-[#5C4033] leading-relaxed">Come by for a complimentary 30-minute visit so we can get to know each other. No commitment required.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-playfair text-white" style="background:#6B8F71;">3</div>
          <h3 class="font-playfair text-xl font-bold text-[#3D2B1F]">Bon Voyage!</h3>
          <p class="text-sm text-[#5C4033] leading-relaxed">Drop off knowing your dog is safe, loved, and already making friends. Photo updates arrive at 8am and 5pm.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-20 px-4" style="background:#F2EAD8;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">The Humans</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">Meet the Team</h2>
        <p class="text-[#5C4033] max-w-xl mx-auto">Certified, passionate, and obsessed with your dog's wellbeing.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {team.map((member) => (
          <div class="rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" style="background:#FAF6EF;">
            <img src={member.photo} alt={`Photo of ${member.name}, ${member.role} at ${business.name}`} class="w-full h-56 object-cover" />
            <div class="p-6">
              <h3 class="font-playfair text-xl font-bold text-[#3D2B1F] mb-1">{member.name}</h3>
              <p class="text-[#C17B50] font-semibold text-sm mb-3">{member.role}</p>
              <p class="text-sm text-[#5C4033] leading-relaxed mb-4">{member.bio}</p>
              <div class="flex flex-wrap gap-2">
                {member.certifications.map((cert) => (
                  <span class="text-xs bg-[#6B8F71]/15 text-[#3D2B1F] rounded-full px-3 py-1 font-medium">{cert}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">🐾 🐾 🐾</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">Pawsitively Reviewed</h2>
        <p class="text-[#5C4033] max-w-xl mx-auto">Real words from real pet parents who trust us every time.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="rounded-2xl p-8 flex flex-col gap-4 shadow-sm hover:shadow-md transition-shadow" style="background:#F2EAD8; border:1px solid #e0d4bc;">
            <div class="flex gap-1 text-[#C17B50] text-lg" aria-label={`${t.stars} out of 5 stars`}>
              {'★'.repeat(t.stars)}
            </div>
            <blockquote class="text-[#5C4033] leading-relaxed italic flex-grow">"{t.text}"</blockquote>
            <div>
              <p class="font-bold text-[#3D2B1F]">{t.name}</p>
              <p class="text-xs text-[#9C7B6C]">{t.breed} · {t.date}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4" style="background:#FAF6EF;">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Questions</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F]">Frequently Asked</h2>
      </div>
      <div class="flex flex-col gap-3" id="v1-faq">
        {[
          { q: 'How many dogs do you board at once?', a: 'We cap overnight boarding at 12 dogs total—never more. Small is intentional.' },
          { q: 'Do you have cameras I can check?', a: 'We send photo updates at 8am and 5pm daily. We\'re exploring live feeds for 2026.' },
          { q: 'Can my dog sleep in a bed?', a: 'Absolutely. Every suite has an orthopedic dog bed. Bring their blanket—familiar smells help.' },
          { q: 'What if my dog gets sick?', a: 'We have a vet partner two blocks away. Any concern is addressed immediately and you\'re called first.' },
          { q: 'Do you accept intact dogs?', a: 'We accept intact males under 1 year in daycare only. Intact females in heat are not accepted for safety reasons.' },
        ].map((item, i) => (
          <div class="rounded-2xl overflow-hidden" style="background:#F2EAD8; border:1px solid #e0d4bc;">
            <button class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between gap-4 font-playfair text-lg font-bold text-[#3D2B1F] hover:text-[#6B8F71] transition-colors" data-idx={i}>
              <span>{item.q}</span>
              <span class="faq-caret text-[#6B8F71] text-xl flex-shrink-0 transition-transform duration-300">+</span>
            </button>
            <div class="faq-answer overflow-hidden" style="max-height:0; transition:max-height 0.35s ease;">
              <p class="px-6 pb-5 text-sm text-[#5C4033] leading-relaxed border-l-4 ml-6 mb-5" style="border-color:#6B8F71;">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOOKING FORM -->
  <section id="booking" class="py-20 px-4" style="background:#F2EAD8;">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Let's Get Started</p>
        <h2 class="font-playfair text-4xl md:text-5xl font-bold text-[#3D2B1F] mb-4">Book a Stay</h2>
        <p class="text-[#5C4033]">Fill out the form and we'll confirm your reservation within 24 hours.</p>
      </div>
      <div id="v1-booking-form-wrap" class="rounded-2xl p-8 shadow-md" style="background:#FAF6EF; border:1px solid #e0d4bc;">
        <form id="v1-booking-form" class="flex flex-col gap-5" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v1-owner-name" class="text-sm font-semibold text-[#3D2B1F]">Owner Name <span class="text-[#C17B50]">*</span></label>
              <input id="v1-owner-name" name="ownerName" type="text" required placeholder="Your full name" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v1-pet-name" class="text-sm font-semibold text-[#3D2B1F]">Pet Name <span class="text-[#C17B50]">*</span></label>
              <input id="v1-pet-name" name="petName" type="text" required placeholder="Your dog's name" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v1-email" class="text-sm font-semibold text-[#3D2B1F]">Email <span class="text-[#C17B50]">*</span></label>
              <input id="v1-email" name="email" type="email" required placeholder="you@email.com" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v1-phone" class="text-sm font-semibold text-[#3D2B1F]">Phone <span class="text-[#C17B50]">*</span></label>
              <input id="v1-phone" name="phone" type="tel" required placeholder="(415) 000-0000" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v1-breed" class="text-sm font-semibold text-[#3D2B1F]">Breed</label>
              <input id="v1-breed" name="breed" type="text" placeholder="e.g. Goldendoodle" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v1-service" class="text-sm font-semibold text-[#3D2B1F]">Service <span class="text-[#C17B50]">*</span></label>
              <select id="v1-service" name="service" required class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F]">
                <option value="">Select a service…</option>
                {services.map((s) => <option value={s.name}>{s.name}</option>)}
              </select>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="v1-date" class="text-sm font-semibold text-[#3D2B1F]">Preferred Start Date <span class="text-[#C17B50]">*</span></label>
            <input id="v1-date" name="date" type="date" required class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F]" />
          </div>
          <div class="flex flex-col gap-1">
            <label for="v1-notes" class="text-sm font-semibold text-[#3D2B1F]">Special Needs / Notes</label>
            <textarea id="v1-notes" name="notes" rows="4" placeholder="Dietary needs, medications, behavioral notes, anything we should know…" class="rounded-xl border border-[#e0d4bc] px-4 py-3 text-sm bg-white text-[#3D2B1F] placeholder:text-[#9C7B6C] resize-y"></textarea>
          </div>
          <button type="submit" class="btn-terra text-base py-4 text-center font-bold rounded-xl hover:bg-[#a56540] transition-colors">
            Request Reservation
          </button>
        </form>
        <div id="v1-booking-success" class="hidden text-center py-12">
          <div class="text-6xl mb-4">🐾</div>
          <h3 class="font-playfair text-2xl font-bold text-[#3D2B1F] mb-2">We'll be in touch!</h3>
          <p class="text-[#5C4033]">Thanks! We'll contact you within 24 hours to confirm your reservation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#C17B50] font-semibold tracking-widest uppercase text-sm mb-2">Find Us</p>
        <h2 class="font-playfair text-4xl font-bold text-[#3D2B1F] mb-4">Contact & Hours</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-6">
          <div class="rounded-2xl p-6" style="background:#F2EAD8; border:1px solid #e0d4bc;">
            <h3 class="font-playfair text-xl font-bold text-[#3D2B1F] mb-4">Hours of Operation</h3>
            <table class="w-full text-sm text-[#5C4033]">
              <tbody>
                <tr class="border-b border-[#e0d4bc]"><td class="py-2 font-semibold">Monday – Friday</td><td class="py-2 text-right">{business.hours.weekdays}</td></tr>
                <tr class="border-b border-[#e0d4bc]"><td class="py-2 font-semibold">Saturday</td><td class="py-2 text-right">{business.hours.saturday}</td></tr>
                <tr><td class="py-2 font-semibold">Sunday</td><td class="py-2 text-right">{business.hours.sunday}</td></tr>
              </tbody>
            </table>
          </div>
          <div class="rounded-2xl p-6 flex flex-col gap-4" style="background:#F2EAD8; border:1px solid #e0d4bc;">
            <h3 class="font-playfair text-xl font-bold text-[#3D2B1F] mb-1">Get in Touch</h3>
            <a href={`tel:${business.phone}`} class="flex items-center gap-3 text-[#5C4033] hover:text-[#C17B50] transition-colors text-sm">
              <span class="text-xl">📞</span> {business.phone}
            </a>
            <a href={`mailto:${business.email}`} class="flex items-center gap-3 text-[#5C4033] hover:text-[#C17B50] transition-colors text-sm">
              <span class="text-xl">✉️</span> {business.email}
            </a>
            <p class="flex items-start gap-3 text-sm text-[#5C4033]">
              <span class="text-xl">📍</span> {business.address}
            </p>
            <p class="flex items-center gap-3 text-sm text-[#9C7B6C]">
              <span class="text-xl">🚨</span> Emergency: {business.emergency}
            </p>
            <p class="text-xs text-[#9C7B6C] mt-2">{business.license}</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-sm" style="min-height:300px; background:#e0d4bc;">
          <iframe
            title={`Map showing location of ${business.name} in ${business.neighborhood}`}
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.8354345532713!2d-122.43284848468192!3d37.77492927975804!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80858092de23eeab%3A0x5dffa5e9e4b12c6b!2sHayes%20Valley%2C%20San%20Francisco%2C%20CA!5e0!3m2!1sen!2sus!4v1620000000000!5m2!1sen!2sus"
            width="100%" height="100%" style="border:0; min-height:300px;"
            allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background:#3D2B1F;" class="py-14 px-4 pb-16 md:pb-14">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-3 gap-10">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🐾</span>
          <span class="font-playfair text-xl font-bold text-white">{business.name}</span>
        </div>
        <p class="text-[#9C7B6C] text-sm leading-relaxed">{business.description}</p>
        <p class="text-[#9C7B6C] text-xs mt-4">{business.instagram}</p>
      </div>
      <div>
        <h4 class="font-playfair text-base font-bold text-white mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#services" class="text-[#9C7B6C] hover:text-[#C17B50] transition-colors">Services</a></li>
          <li><a href="#pricing" class="text-[#9C7B6C] hover:text-[#C17B50] transition-colors">Pricing</a></li>
          <li><a href="#gallery" class="text-[#9C7B6C] hover:text-[#C17B50] transition-colors">Gallery</a></li>
          <li><a href="#team" class="text-[#9C7B6C] hover:text-[#C17B50] transition-colors">Our Team</a></li>
          <li><a href="#booking" class="text-[#9C7B6C] hover:text-[#C17B50] transition-colors">Book Now</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-playfair text-base font-bold text-white mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-[#9C7B6C]">
          <li>{business.address}</li>
          <li><a href={`tel:${business.phone}`} class="hover:text-[#C17B50] transition-colors">{business.phone}</a></li>
          <li><a href={`mailto:${business.email}`} class="hover:text-[#C17B50] transition-colors">{business.email}</a></li>
        </ul>
        <p class="text-xs text-[#5C4033] mt-6">© {new Date().getFullYear()} {business.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE CTA BAR -->
  <div class="fixed bottom-0 left-0 right-0 z-50 flex md:hidden" style="height:56px;">
    <a href="tel:+14158823047" class="flex-1 flex items-center justify-center gap-2 text-white font-bold text-sm" style="background:#3D2B1F;">
      <span>📞</span> (415) 882-3047
    </a>
    <a href="#booking" class="flex-1 flex items-center justify-center gap-2 text-white font-bold text-sm" style="background:#C17B50;">
      Book Now
    </a>
  </div>

  <script>
    const btn = document.getElementById('v1-menu-btn');
    const menu = document.getElementById('v1-mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
      document.querySelectorAll('#v1-mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => menu.classList.add('hidden'));
      });
    }
    const form = document.getElementById('v1-booking-form') as HTMLFormElement | null;
    const formWrap = document.getElementById('v1-booking-form-wrap');
    const success = document.getElementById('v1-booking-success');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (form) form.classList.add('hidden');
        if (success) success.classList.remove('hidden');
      });
    }
    // FAQ accordion
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const parent = trigger.parentElement;
        if (!parent) return;
        const answer = parent.querySelector('.faq-answer') as HTMLElement | null;
        const caret = trigger.querySelector('.faq-caret') as HTMLElement | null;
        const isOpen = trigger.classList.contains('faq-open');
        // close all
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.classList.remove('faq-open');
          const p = t.parentElement;
          if (p) {
            const a = p.querySelector('.faq-answer') as HTMLElement | null;
            const c = t.querySelector('.faq-caret') as HTMLElement | null;
            if (a) a.style.maxHeight = '0';
            if (c) { c.textContent = '+'; c.style.transform = 'rotate(0deg)'; }
          }
        });
        if (!isOpen && answer && caret) {
          trigger.classList.add('faq-open');
          answer.style.maxHeight = '500px';
          caret.textContent = '−';
          caret.style.transform = 'rotate(0deg)';
        }
      });
    });
  </script>
</BaseLayout>
