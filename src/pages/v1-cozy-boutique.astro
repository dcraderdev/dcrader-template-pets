---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v1/business';
import { services, packages } from '../data/v1/services';
import { gallery } from '../data/v1/gallery';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "telephone": business.phone,
  "email": business.email,
  "address": { "@type": "PostalAddress", "streetAddress": business.address },
  "url": "https://pets.dcrader.dev/v1-cozy-boutique",
  "priceRange": "$$",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "312" },
  "openingHours": ["Mo-Fr 07:00-19:00", "Sa 08:00-18:00", "Su 09:00-17:00"],
});
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1200&h=630&fit=crop&q=80"
  heroImage="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=1600&h=900&fit=crop&q=80"
  schemaJson={schemaJson}
>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v1-banner" style="background:#6B8F71;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative">
    <span>🐾 New clients: First day of daycare FREE with overnight booking · Limited spots · (415) 882-3047</span>
    <button onclick="document.getElementById('v1-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600;700&display=swap');

    :root {
      --cream: #FAF6EF;
      --card: #F2EAD8;
      --sage: #6B8F71;
      --blush: #E8B4B8;
      --terra: #C17B50;
      --brown-dark: #3D2B1F;
      --brown-body: #5C4033;
      --muted: #9C7B6C;
    }
    html { scroll-behavior: smooth; }
    body { background: var(--cream); font-family: 'Inter', system-ui, sans-serif; color: var(--brown-body); }
    h1, h2, h3, h4, h5, h6 { font-family: 'Cormorant Garamond', Georgia, serif; }
    .btn-sage { background: #6B8F71; color: #fff; border-radius: 9999px; padding: 0.75rem 2rem; font-weight: 700; transition: background 0.2s; display: inline-block; font-family: 'Inter', system-ui, sans-serif; }
    .btn-sage:hover { background: #557260; }
    .btn-terra { background: #C17B50; color: #fff; border-radius: 9999px; padding: 0.75rem 2rem; font-weight: 700; transition: background 0.2s; display: inline-block; font-family: 'Inter', system-ui, sans-serif; }
    .btn-terra:hover { background: #a56540; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #6B8F71; outline-offset: 2px; }
    section[id] { scroll-margin-top: 5rem; }

    /* Split nav */
    .nav-split { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; }

    /* Polaroid frames */
    .polaroid {
      background: #fff;
      padding: 8px 8px 32px 8px;
      box-shadow: 0 4px 20px rgba(61,43,31,0.25);
      position: absolute;
    }
    .polaroid img { display: block; width: 200px; height: 200px; object-fit: cover; }

    /* Sticky note cards */
    .sticky-card {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .sticky-card:hover {
      transform: rotate(0deg) !important;
      box-shadow: 0 12px 32px rgba(61,43,31,0.18);
    }

    /* Polaroid gallery */
    .gallery-polaroid {
      background: #fff;
      padding: 10px 10px 36px 10px;
      box-shadow: 0 4px 16px rgba(61,43,31,0.18);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: block;
    }
    .gallery-polaroid:hover {
      box-shadow: 0 10px 32px rgba(61,43,31,0.28);
      transform: scale(1.04) rotate(0deg) !important;
    }
    .gallery-polaroid img { display: block; width: 100%; aspect-ratio: 1; object-fit: cover; }

    /* Tape effect for testimonials */
    .tape-strip {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%) rotate(-2deg);
      width: 60px;
      height: 20px;
      background: rgba(107,143,113,0.35);
      border-radius: 2px;
    }

    /* Scrapbook paw print */
    .paw-scatter {
      position: absolute;
      opacity: 0.18;
      font-size: 1rem;
      pointer-events: none;
    }

    /* Form reservation card */
    .reservation-card {
      background: var(--cream);
      border: 1.5px solid #d4c9b5;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(61,43,31,0.10);
    }

    @media (max-width: 768px) {
      .nav-split { display: flex; justify-content: space-between; }
      .nav-links-left, .nav-links-right { display: none; }
    }
  </style>

  <!-- NAV — SPLIT/CENTERED LOGO -->
  <nav style="background:#3D2B1F;" class="sticky top-0 z-50 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 py-4 nav-split">
      <!-- Left links -->
      <div class="nav-links-left hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="#v1-services" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Services</a>
        <a href="#v1-suites" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Suites</a>
        <a href="#v1-pricing" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Pricing</a>
      </div>
      <!-- Mobile: logo left -->
      <a href="#" class="flex items-center gap-2 md:hidden">
        <span class="text-xl">🐾</span>
        <span style="font-family:'Cormorant Garamond',Georgia,serif;" class="text-lg font-bold text-white">{business.name}</span>
      </a>
      <!-- Center logo (desktop only) -->
      <a href="#" class="hidden md:flex items-center justify-center gap-2">
        <span class="text-2xl">🐾</span>
        <span style="font-family:'Cormorant Garamond',Georgia,serif;" class="text-xl font-bold text-white tracking-wide">{business.name}</span>
      </a>
      <!-- Right links -->
      <div class="nav-links-right hidden md:flex items-center gap-6 text-sm font-semibold justify-end">
        <a href="#v1-gallery" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Gallery</a>
        <a href="#v1-team" class="text-[#F2EAD8] hover:text-[#C17B50] transition-colors">Team</a>
        <a href="#v1-booking" class="btn-sage text-sm py-2 px-5">Book Now →</a>
      </div>
      <!-- Mobile hamburger -->
      <button id="v1-menu-btn" class="md:hidden text-white text-2xl" aria-label="Open menu">☰</button>
    </div>
    <!-- Mobile menu -->
    <div id="v1-mobile-menu" class="hidden md:hidden px-6 pb-5 flex flex-col gap-3">
      <a href="#v1-services" class="text-[#F2EAD8] text-sm font-semibold py-1 border-b border-white/10">Services</a>
      <a href="#v1-suites" class="text-[#F2EAD8] text-sm font-semibold py-1 border-b border-white/10">Suites</a>
      <a href="#v1-pricing" class="text-[#F2EAD8] text-sm font-semibold py-1 border-b border-white/10">Pricing</a>
      <a href="#v1-gallery" class="text-[#F2EAD8] text-sm font-semibold py-1 border-b border-white/10">Gallery</a>
      <a href="#v1-team" class="text-[#F2EAD8] text-sm font-semibold py-1 border-b border-white/10">Team</a>
      <a href="#v1-booking" class="btn-sage text-sm py-2 px-5 text-center mt-2">Book Now →</a>
    </div>
  </nav>

  <!-- HERO — ASYMMETRIC SPLIT -->
  <section id="v1-hero" style="display:grid; grid-template-columns:55fr 45fr; min-height:90vh;">
    <!-- LEFT: cream content panel -->
    <div style="background:#FAF6EF; padding:120px 56px 80px 56px;" class="flex flex-col justify-center">
      <p style="color:#6B8F71; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:1.5rem;">Est. {business.founded} · Hayes Valley, San Francisco</p>
      <h1 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(3rem,5.5vw,5rem); font-weight:700; color:#3D2B1F; line-height:1.08; margin-bottom:1rem;">
        Where Every Dog<br/>Stays Like<br/>A Guest
      </h1>
      <!-- Squiggly SVG underline decoration -->
      <svg width="260" height="18" viewBox="0 0 260 18" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-bottom:1.75rem; margin-top:-0.25rem;">
        <path d="M2 14 C20 4, 40 18, 60 10 C80 2, 100 16, 120 9 C140 2, 160 16, 180 9 C200 2, 220 16, 240 8 C250 4, 256 10, 258 8" stroke="#6B8F71" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      </svg>
      <p style="font-family:'Inter',system-ui,sans-serif; color:#5C4033; font-size:1.125rem; line-height:1.7; max-width:400px; margin-bottom:2.5rem;">{business.tagline}</p>
      <div style="display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:2.5rem;">
        <a href="#v1-booking" class="btn-sage" style="font-size:1rem; padding:0.85rem 2.25rem;">Reserve a Stay</a>
        <a href="#v1-services" style="border:2px solid #3D2B1F; color:#3D2B1F; border-radius:9999px; padding:0.85rem 2.25rem; font-weight:700; font-family:'Inter',system-ui,sans-serif; font-size:1rem; transition:all 0.2s; display:inline-block;" class="hover:bg-[#3D2B1F] hover:text-white transition-all">Explore Services</a>
      </div>
      <!-- Trust row -->
      <div style="display:flex; flex-wrap:wrap; gap:1.25rem; font-size:0.8rem; color:#9C7B6C; font-family:'Inter',system-ui,sans-serif;">
        <span>⭐ 4.9 (312 reviews)</span>
        <span>🔒 Licensed & Insured</span>
        <span>📸 Photo updates daily</span>
        <span>🏥 Fear Free Certified</span>
      </div>
    </div>
    <!-- RIGHT: dark scrapbook panel -->
    <div style="background:#3D2B1F; position:relative; overflow:hidden; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:500px;">
      <!-- Scattered paw prints -->
      <span class="paw-scatter" style="top:8%; left:10%; transform:rotate(20deg);">🐾</span>
      <span class="paw-scatter" style="bottom:12%; right:8%; transform:rotate(-30deg);">🐾</span>
      <span class="paw-scatter" style="top:55%; left:5%; transform:rotate(10deg);">🐾</span>
      <span class="paw-scatter" style="top:20%; right:6%; transform:rotate(-15deg);">🐾</span>

      <!-- Polaroid collage -->
      <div style="position:relative; width:340px; height:360px; margin:0 auto;">
        <!-- Photo 1: top-left, tilted left -->
        <div class="polaroid" style="top:0; left:0; transform:rotate(-3deg); z-index:1;">
          <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?w=300&h=300&fit=crop" alt="Happy dog guest at Paws and Pine" width="200" height="200" />
        </div>
        <!-- Photo 2: center-right, tilted right -->
        <div class="polaroid" style="top:40px; right:0; transform:rotate(2deg); z-index:2;">
          <img src="https://images.unsplash.com/photo-1510771463146-e89e6e86560e?w=300&h=300&fit=crop" alt="Dog playing at Paws and Pine" width="200" height="200" />
        </div>
        <!-- Photo 3: bottom-left, slight tilt -->
        <div class="polaroid" style="bottom:0; left:30px; transform:rotate(-1.5deg); z-index:3;">
          <img src="https://images.unsplash.com/photo-1537151608828-ea2b11777ee8?w=300&h=300&fit=crop" alt="Cozy dog lounging at Paws and Pine" width="200" height="200" />
        </div>
      </div>

      <!-- Caption below polaroids -->
      <p style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; color:rgba(250,246,239,0.6); font-size:1rem; margin-top:1.5rem; text-align:center; letter-spacing:0.03em;">Real guests. Real love.</p>
    </div>
  </section>
  <!-- Mobile hero fix: stack on small screens -->
  <style>
    @media (max-width: 768px) {
      #v1-hero { grid-template-columns: 1fr !important; }
      #v1-hero > div:first-child { padding: 72px 24px 48px 24px !important; }
      #v1-hero > div:last-child { min-height: 420px !important; }
    }
  </style>

  <!-- SERVICES — STICKY NOTE CARDS -->
  <section id="v1-services" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p style="color:#C17B50; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:0.5rem;">What We Offer</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.25rem,4vw,3.25rem); font-weight:700; color:#3D2B1F; margin-bottom:0.75rem;">Our Services</h2>
        <!-- Squiggly underline -->
        <svg width="180" height="14" viewBox="0 0 180 14" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin:0 auto 1rem;">
          <path d="M2 10 C18 2, 35 14, 52 7 C69 0, 86 13, 103 6 C120 0, 137 13, 154 6 C164 2, 174 9, 178 7" stroke="#6B8F71" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
        <p style="color:#5C4033; max-width:480px; margin:0 auto; font-size:1.05rem; font-family:'Inter',system-ui,sans-serif;">Tailored care for every dog, every visit. Because your pet deserves more than the basics.</p>
      </div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:1.5rem;">
        {services.map((s, i) => {
          const rotations = ['-1deg', '1.5deg', '-0.5deg', '2deg'];
          const bgs = ['#FAF6EF', '#F9EAEB', '#EEF3EF', '#FFFDF8'];
          const rot = rotations[i % rotations.length];
          const bg = bgs[i % bgs.length];
          return (
            <div class="sticky-card rounded-2xl p-6 flex flex-col gap-3 shadow-sm" style={`background:${bg}; border:1px solid #e0d4bc; transform:rotate(${rot});`}>
              <div style="font-size:2.25rem;">{s.icon}</div>
              <h3 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:1.35rem; font-weight:700; color:#3D2B1F;">{s.name}</h3>
              <p style="font-size:0.875rem; color:#5C4033; line-height:1.65; flex-grow:1;">{s.description}</p>
              <p style="font-weight:700; color:#C17B50; font-size:1.1rem; font-family:'Cormorant Garamond',Georgia,serif;">{s.price}</p>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.35rem;">
                {s.highlights.map((h) => (
                  <li style="font-size:0.78rem; color:#5C4033; display:flex; align-items:flex-start; gap:0.5rem;">
                    <span style="color:#6B8F71; font-weight:700; flex-shrink:0;">✓</span> {h}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- STATS STRIP — DARK HORIZONTAL BAND -->
  <section style="background:#3D2B1F; padding:3rem 1rem;">
    <div class="max-w-5xl mx-auto" style="display:grid; grid-template-columns:repeat(4, 1fr); gap:1.5rem; text-align:center;">
      {[
        { n: '5,000+', label: 'Dog-Nights Booked' },
        { n: '4.9★', label: '312 Reviews' },
        { n: '12', label: 'Max Dogs at Once' },
        { n: '2×', label: 'Daily Photo Updates' },
      ].map((s) => (
        <div>
          <div style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2rem,4vw,3.25rem); font-weight:700; color:#C17B50; line-height:1.1;">{s.n}</div>
          <p style="color:rgba(250,246,239,0.65); font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; margin-top:0.35rem; font-family:'Inter',system-ui,sans-serif;">{s.label}</p>
        </div>
      ))}
    </div>
    <style>
      @media (max-width: 640px) {
        #v1-stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
      }
    </style>
  </section>

  <!-- PRICING — PACKAGE CARDS -->
  <section id="v1-pricing" class="py-20 px-4" style="background:#F2EAD8;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p style="color:#C17B50; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:0.5rem;">Packages</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.25rem,4vw,3.25rem); font-weight:700; color:#3D2B1F; margin-bottom:0.75rem;">Choose Your Stay</h2>
        <p style="color:#5C4033; max-width:480px; margin:0 auto; font-family:'Inter',system-ui,sans-serif;">Bundle and save — every package includes our standard of attentive, personal care.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 items-start">
        {packages.map((pkg) => (
          <div class={`rounded-2xl p-8 flex flex-col gap-4 relative ${pkg.featured ? 'shadow-2xl scale-105' : 'shadow-sm'}`}
               style={pkg.featured ? 'background:#6B8F71; color:#fff;' : 'background:#FAF6EF; border:1px solid #e0d4bc;'}>
            {pkg.featured && <div style="position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:#C17B50; color:#fff; font-size:0.7rem; font-weight:700; padding:4px 16px; border-radius:9999px; white-space:nowrap; font-family:'Inter',system-ui,sans-serif;">Most Popular</div>}
            <div>
              <h3 style={`font-family:'Cormorant Garamond',Georgia,serif; font-size:1.6rem; font-weight:700; margin-bottom:0.25rem; color:${pkg.featured ? '#fff' : '#3D2B1F'};`}>{pkg.name}</h3>
              <p style={`font-size:0.8rem; font-family:'Inter',system-ui,sans-serif; color:${pkg.featured ? 'rgba(255,255,255,0.75)' : '#9C7B6C'};`}>{pkg.period}</p>
            </div>
            <div style={`font-family:'Cormorant Garamond',Georgia,serif; font-size:2.5rem; font-weight:700; color:${pkg.featured ? '#fff' : '#C17B50'};`}>{pkg.price}</div>
            <p style={`font-size:0.875rem; font-family:'Inter',system-ui,sans-serif; color:${pkg.featured ? 'rgba(255,255,255,0.85)' : '#5C4033'};`}>{pkg.description}</p>
            <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem; flex-grow:1;">
              {pkg.features.map((f) => (
                <li style={`font-size:0.875rem; display:flex; align-items:flex-start; gap:0.5rem; font-family:'Inter',system-ui,sans-serif; color:${pkg.featured ? 'rgba(255,255,255,0.9)' : '#5C4033'};`}>
                  <span style={`color:${pkg.featured ? '#F2EAD8' : '#6B8F71'}; font-weight:700; flex-shrink:0; margin-top:1px;`}>✓</span> {f}
                </li>
              ))}
            </ul>
            <a href="#v1-booking" class={pkg.featured ? '' : 'btn-sage'} style={pkg.featured ? 'display:block; text-align:center; background:#fff; color:#6B8F71; border-radius:9999px; padding:0.75rem 1.5rem; font-weight:700; font-family:Inter,system-ui,sans-serif; font-size:0.9rem; margin-top:0.5rem;' : 'text-align:center; font-size:0.9rem; margin-top:0.5rem;'}>
              Book This Package
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY — POLAROID MASONRY -->
  <section id="v1-gallery" class="py-20 px-4" style="background:#FAF6EF;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p style="color:#C17B50; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:0.5rem;">Life at Paws & Pine</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.25rem,4vw,3.25rem); font-weight:700; color:#3D2B1F; margin-bottom:0.75rem;">The Gallery</h2>
        <p style="color:#5C4033; max-width:440px; margin:0 auto; font-family:'Inter',system-ui,sans-serif;">A glimpse of everyday joy — real guests, real moments.</p>
      </div>
      <div style="columns:3; column-gap:1.5rem;" class="v1-gallery-columns">
        {gallery.map((img, i) => {
          const rot = i % 2 === 0 ? '1.5deg' : '-1.5deg';
          return (
            <div style={`break-inside:avoid; margin-bottom:1.5rem;`}>
              <div class="gallery-polaroid" style={`transform:rotate(${rot});`}>
                <img src={img.url} alt={img.alt} loading="lazy" style="display:block; width:100%; aspect-ratio:1; object-fit:cover;" />
                <p style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; color:#9C7B6C; font-size:0.8rem; text-align:center; padding-top:6px; margin:0;">{img.caption}</p>
              </div>
            </div>
          );
        })}
      </div>
      <style>
        @media (max-width: 768px) { .v1-gallery-columns { columns: 2 !important; } }
        @media (max-width: 480px) { .v1-gallery-columns { columns: 1 !important; } }
      </style>
    </div>
  </section>

  <!-- TEAM — CARD GRID -->
  <section id="v1-team" class="py-20 px-4" style="background:#F2EAD8;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p style="color:#C17B50; font-family:'Inter',system-ui,sans-serif; font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-bottom:0.5rem;">The Humans</p>
        <h2 style="font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.25rem,4vw,3.25rem); font-weight:700; color:#3D2B1F; margin-bottom:0.75rem;">Meet the Team</h2>
        <p style="color:#5C4033; max-width:480px; margin:0 auto; font-family:'Inter',system-ui,sans-serif;">Certified, passionate, and obsessed with your dog's wellbeing.</p>
      </div>
