              <blockquote style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; color:#5C4033; line-height:1.65; font-size:1.05rem; flex-grow:1; margin:0 0 1.25rem;">"{t.text}"</blockquote>
              <div>
                <p style="font-weight:700; color:#3D2B1F; font-family:'Cormorant Garamond',Georgia,serif; font-size:1rem;">{t.name}</p>
                <p style="font-size:0.75rem; color:#9C7B6C; font-family:'Inter',system-ui,sans-serif;">{t.breed} · {t.date}</p>
              </div>
            </div>
          );
        })}
      </div>
      <div class="text-center mt-10">
        <a href="#" style="display:inline-flex; align-items:center; gap:0.5rem; font-size:0.875rem; font-weight:600; color:#5C4033; font-family:'Inter',system-ui,sans-serif;" class="hover:text-[#C17B50] transition-colors">
          <span style="color:#C17B50;">★★★★★</span> Read all 312 reviews on Google
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
