---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v2/business';
import { services, packages } from '../data/v2/services';
import { gallery } from '../data/v2/gallery';
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=1200&h=630&fit=crop&q=80"
  heroImage="https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=1600&h=900&fit=crop&q=80"
>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v2-banner" style="background:#1A4731;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative border-b-2 border-[#F5A623]">
    <span>🏔️ Summer hike packs now open — book before June 30, save 15% · (720) 443-8821</span>
    <button onclick="document.getElementById('v2-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    body { font-family: 'Open Sans', sans-serif; background: #F8F7F4; color: #2D3A2A; }
    .font-oswald { font-family: 'Oswald', sans-serif; }
    .hero-bg-v2 {
      background-image: linear-gradient(rgba(26,71,49,0.52), rgba(26,71,49,0.62)),
        url('https://images.unsplash.com/photo-1601758125946-6ec2ef64daf8?w=1600&h=900&fit=crop&q=80');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }
    .skew-down { clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%); }
    .skew-up { clip-path: polygon(0 0, 100% 15%, 100% 100%, 0 100%); margin-top: -5rem; }
    .btn-yellow { background: #F5A623; color: #1A4731; border-radius: 4px; padding: 0.85rem 2rem; font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s; display: inline-block; }
    .btn-yellow:hover { background: #e09610; }
    .btn-green { background: #1A4731; color: #fff; border-radius: 4px; padding: 0.85rem 2rem; font-family: 'Oswald', sans-serif; font-weight: 600; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; transition: background 0.2s; display: inline-block; }
    .btn-green:hover { background: #0F2A1D; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #F5A623; outline-offset: 2px; }
  html { scroll-behavior: smooth; }
  section[id] { scroll-margin-top: 5rem; }
  @media (max-width: 768px) { .hero-bg-v2 { background-attachment: scroll; } }
  </style>

  <!-- NAV -->
  <nav style="background:#1A4731;" class="sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl">⛰️</span>
        <span class="font-oswald text-xl font-bold text-white tracking-wider uppercase">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="#services" class="text-[#F5A623] hover:text-white transition-colors uppercase tracking-wide font-oswald">Services</a>
        <a href="#pricing" class="text-[#F5A623] hover:text-white transition-colors uppercase tracking-wide font-oswald">Pricing</a>
        <a href="#gallery" class="text-[#F5A623] hover:text-white transition-colors uppercase tracking-wide font-oswald">Gallery</a>
        <a href="#team" class="text-[#F5A623] hover:text-white transition-colors uppercase tracking-wide font-oswald">Team</a>
        <a href="#booking" class="btn-yellow text-sm py-2 px-5">Join the Pack</a>
      </div>
      <button id="v2-menu-btn" class="md:hidden text-white text-2xl" aria-label="Open menu">☰</button>
    </div>
    <div id="v2-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3">
      <a href="#services" class="text-[#F5A623] text-sm font-semibold uppercase font-oswald">Services</a>
      <a href="#pricing" class="text-[#F5A623] text-sm font-semibold uppercase font-oswald">Pricing</a>
      <a href="#gallery" class="text-[#F5A623] text-sm font-semibold uppercase font-oswald">Gallery</a>
      <a href="#team" class="text-[#F5A623] text-sm font-semibold uppercase font-oswald">Team</a>
      <a href="#booking" class="btn-yellow text-sm py-2 px-5 text-center">Join the Pack</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero" class="hero-bg-v2 min-h-screen flex items-center px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-[#F5A623] font-oswald tracking-widest uppercase text-sm mb-4 font-semibold">Boulder, CO · Est. {business.founded}</p>
      <h1 class="font-oswald text-6xl md:text-8xl font-bold text-white leading-none uppercase mb-6">
        Real Trails.<br/>
        <span style="color:#F5A623;">Real Exercise.</span><br/>
        Happy Dogs.
      </h1>
      <p class="text-white/85 text-xl mb-4 max-w-xl">GPS-tracked adventure hikes starting at $45 · {business.neighborhood}</p>
      <p class="text-white/70 text-base mb-10 max-w-lg">{business.description}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#booking" class="btn-yellow text-base px-10 py-4">Book a Hike</a>
        <a href="#services" class="border-2 border-[#F5A623] text-[#F5A623] font-oswald uppercase tracking-wide px-10 py-4 hover:bg-[#F5A623] hover:text-[#1A4731] transition-all text-base">Our Services</a>
      </div>
      <div class="mt-14 grid grid-cols-2 sm:grid-cols-4 gap-6">
        {[
          { icon: '🛰️', label: 'GPS Tracked Every Hike' },
          { icon: '🏔️', label: '420+ Trails Completed' },
          { icon: '🐕', label: 'Max 5 Dogs / Guide' },
          { icon: '⭐', label: '4.9 · 218 Reviews' },
        ].map((b) => (
          <div class="text-center">
            <div class="text-3xl mb-1">{b.icon}</div>
            <p class="text-white/80 text-xs font-semibold uppercase tracking-wider">{b.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-20 px-4 skew-down" style="background:#1A4731; padding-bottom:7rem;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-white uppercase mb-3">What We Do</h2>
        <p class="text-white/70 max-w-xl mx-auto">Every service is designed for dogs who need more than a walk around the block.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((s, i) => (
          <div class="bg-white rounded-sm p-6 flex flex-col gap-3 hover:shadow-xl transition-shadow group" style={`border-top: 5px solid ${i % 2 === 0 ? '#1A4731' : '#F5A623'};`}>
            <div class="text-4xl group-hover:scale-110 transition-transform">{s.icon}</div>
            <h3 class="font-oswald text-xl font-bold text-[#1A4731] uppercase">{s.name}</h3>
            <p class="text-sm text-[#2D3A2A] leading-relaxed flex-grow">{s.description}</p>
            <span class="inline-block bg-[#F5A623] text-[#1A4731] font-oswald font-bold text-sm px-3 py-1 self-start">{s.price}</span>
            <ul class="space-y-1 mt-1">
              {s.highlights.map((h) => (
                <li class="text-xs text-[#2D3A2A] flex items-center gap-2">
                  <span class="text-[#1A4731] font-bold">→</span> {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HEALTH & REQUIREMENTS -->
  <section class="py-16 px-4" style="background:#F8F7F4;">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-sm p-8 md:p-10" style="background:#fff; border-left:5px solid #1A4731; border:1px solid #ddd; border-left-width:5px; border-left-color:#1A4731;">
        <h2 class="font-oswald text-3xl md:text-4xl font-bold text-[#1A4731] uppercase mb-2">Health &amp; Requirements</h2>
        <p class="text-[#2D3A2A]/60 mb-8 text-sm">Every dog on the trail must meet these standards — no exceptions.</p>
        <div class="grid sm:grid-cols-2 gap-6">
          {[
            { n: '01', title: 'Vaccination Requirements', body: 'Current Rabies, Bordetella (within 6 months), and DHPP/DA2PP required. Records verified before first hike.' },
            { n: '02', title: 'Temperament Assessment', body: 'New dogs complete a free 30-min meet & greet. We match trail intensity to the dog — never the other way around.' },
            { n: '03', title: 'Health on Hike Day', body: 'Dogs must be flea/tick treated, not in heat, and free of contagious illness on every hike day.' },
            { n: '04', title: 'Emergency Protocol', body: '24/7 vet partner on call. GPS tracking means we know exactly where your dog is at all times. You\'re notified immediately of any incident.' },
          ].map((item) => (
            <div class="flex gap-4">
              <div class="font-oswald text-4xl font-bold text-[#F5A623] flex-shrink-0 leading-none">{item.n}</div>
              <div>
                <h3 class="font-oswald text-lg font-bold text-[#1A4731] uppercase mb-1">{item.title}</h3>
                <p class="text-sm text-[#2D3A2A] leading-relaxed">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-20 px-4" style="background:#F8F7F4; padding-top:7rem;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-[#1A4731] uppercase mb-3">Memberships</h2>
        <p class="text-[#2D3A2A] max-w-xl mx-auto">Pick a plan. Your dog will thank you every single week.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {packages.map((pkg) => (
          <div class={`rounded-sm flex flex-col gap-4 overflow-hidden ${pkg.featured ? 'shadow-2xl' : 'shadow-sm'}`}
               style={pkg.featured ? 'background:#1A4731;' : 'background:#fff; border: 1px solid #ddd;'}>
            {pkg.featured && <div class="bg-[#F5A623] text-[#1A4731] text-xs font-oswald font-bold py-2 px-4 text-center uppercase tracking-wider">Best Value — Summit Pass</div>}
            <div class="p-8 flex flex-col gap-4 flex-grow">
              <div>
                <h3 class="font-oswald text-2xl font-bold uppercase mb-1" style={pkg.featured ? 'color:#fff' : 'color:#1A4731'}>{pkg.name}</h3>
                <p class="text-sm" style={pkg.featured ? 'color:rgba(255,255,255,0.7)' : 'color:#888'}>{pkg.period}</p>
              </div>
              <div class="text-5xl font-oswald font-bold" style={pkg.featured ? 'color:#F5A623' : 'color:#1A4731'}>{pkg.price}</div>
              <p class="text-sm" style={pkg.featured ? 'color:rgba(255,255,255,0.8)' : 'color:#2D3A2A'}>{pkg.description}</p>
              <ul class="space-y-2 flex-grow">
                {pkg.features.map((f) => (
                  <li class="text-sm flex items-start gap-2" style={pkg.featured ? 'color:rgba(255,255,255,0.9)' : 'color:#2D3A2A'}>
                    <span style={pkg.featured ? 'color:#F5A623' : 'color:#E87B3A'} class="font-bold mt-0.5">✓</span> {f}
                  </li>
                ))}
              </ul>
              <a href="#booking" class={`text-center font-oswald uppercase tracking-wide py-3 px-6 text-base transition-all mt-2 ${pkg.featured ? 'btn-yellow' : 'btn-green'}`}>
                Get Started
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="py-20 px-4 skew-up" style="background:#0F2A1D; padding-top:8rem; padding-bottom:6rem;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-white uppercase mb-3">On the Trail</h2>
        <p class="text-white/60 max-w-xl mx-auto">Real adventures. Real dogs. Real exhaustion (the good kind).</p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {gallery.map((img) => (
          <div class="group overflow-hidden relative" style="aspect-ratio:1;">
            <img src={img.url} alt={img.alt} loading="lazy"
              class="w-full h-full object-cover group-hover:scale-110 group-hover:rotate-1 transition-all duration-500" />
            <div class="absolute inset-0 bg-[#1A4731]/0 group-hover:bg-[#1A4731]/50 transition-all flex items-end p-3">
              <p class="text-white text-xs font-oswald uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity">{img.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 px-4" style="background:#F8F7F4;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-oswald text-4xl md:text-5xl font-bold text-[#1A4731] uppercase">Getting Started</h2>
        <div class="mt-3 w-16 h-1 bg-[#F5A623] mx-auto"></div>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-sm flex items-center justify-center text-2xl font-bold font-oswald text-[#1A4731]" style="background:#F5A623;">1</div>
          <h3 class="font-oswald text-xl font-bold text-[#1A4731] uppercase">Tell Us About Your Dog</h3>
          <p class="text-sm text-[#2D3A2A] leading-relaxed">Submit your dog's info, fitness level, and any behavioral notes. Takes 3 minutes.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-sm flex items-center justify-center text-2xl font-bold font-oswald text-white" style="background:#1A4731;">2</div>
          <h3 class="font-oswald text-xl font-bold text-[#1A4731] uppercase">Temperament Hike</h3>
          <p class="text-sm text-[#2D3A2A] leading-relaxed">Your dog joins a trial hike. We assess fitness, recall, and pack compatibility on real terrain.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-sm flex items-center justify-center text-2xl font-bold font-oswald text-[#1A4731]" style="background:#F5A623;">3</div>
          <h3 class="font-oswald text-xl font-bold text-[#1A4731] uppercase">Join the Pack</h3>
          <p class="text-sm text-[#2D3A2A] leading-relaxed">You're in. Book hikes weekly, track GPS live, and get a post-hike report every time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-20 px-4" style="background:#F8F7F4;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-[#1A4731] uppercase mb-3">Your Guides</h2>
        <p class="text-[#2D3A2A] max-w-xl mx-auto">Wilderness-certified professionals who love dogs as much as they love the mountains.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map((member) => (
          <div class="rounded-sm overflow-hidden" style="background:#1A4731;">
            <img src={member.photo} alt={`Photo of ${member.name}, ${member.role} at ${business.name}`} class="w-full h-52 object-cover" />
            <div class="p-6">
              <h3 class="font-oswald text-2xl font-bold text-white uppercase mb-1">{member.name}</h3>
              <p class="text-[#F5A623] font-oswald text-sm uppercase tracking-wider mb-3">{member.role}</p>
              <p class="text-sm text-white/75 leading-relaxed mb-4">{member.bio}</p>
              <div class="flex flex-wrap gap-2">
                {member.certifications.map((cert) => (
                  <span class="text-xs bg-white/10 text-white/80 rounded-sm px-3 py-1">{cert}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-20 px-4" style="background:#1A4731;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-white uppercase mb-3">The Pack Speaks</h2>
        <p class="text-white/60 max-w-xl mx-auto">From the owners of the happiest, most-tired dogs in Boulder.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <div class="p-8 flex flex-col gap-4" style="background:rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);">
            <div class="text-[#F5A623] text-5xl font-oswald leading-none">"</div>
            <blockquote class="text-white/85 leading-relaxed flex-grow italic text-sm">{t.text}</blockquote>
            <div class="flex gap-1 text-[#F5A623]" aria-label={`${t.stars} out of 5 stars`}>
              {'★'.repeat(t.stars)}
            </div>
            <div>
              <p class="font-oswald text-white uppercase tracking-wide">{t.name}</p>
              <p class="text-xs text-white/50">{t.breed} · {t.date}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="#" class="inline-flex items-center gap-2 text-sm font-bold text-white/60 hover:text-[#F5A623] transition-colors font-oswald uppercase tracking-wider">
          <span class="text-[#F5A623]">★★★★★</span> Read all 218 reviews on Google
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4" style="background:#F8F7F4;">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-oswald text-4xl md:text-5xl font-bold text-[#1A4731] uppercase">Common Questions</h2>
        <div class="mt-3 w-16 h-1 bg-[#F5A623] mx-auto"></div>
      </div>
      <div class="flex flex-col gap-2" id="v2-faq">
        {[
          { q: 'What fitness level do dogs need?', a: 'We assess every dog. Puppies do shorter routes; seniors get flat trails. We match the trail to the dog.' },
          { q: 'Is hiking off-leash?', a: 'Off-leash only on designated trails where it\'s safe and legal. Your dog must have a solid recall.' },
          { q: 'What if it rains?', a: 'We hike in rain. Dogs are dogs. We skip lightning and extreme conditions only.' },
          { q: 'What vaccinations are required?', a: 'Current Rabies, Bordetella (within 6 months), and DHPP. We verify records before first hike.' },
          { q: 'Do you accept reactive dogs?', a: 'Case by case. Emma does private sessions specifically for reactive dogs—reach out to discuss.' },
        ].map((item, i) => (
          <div style="background:#1A4731;" class="rounded-sm overflow-hidden">
            <button class="faq-trigger w-full text-left px-6 py-4 flex items-center justify-between gap-4 font-oswald text-lg font-bold text-white uppercase hover:text-[#F5A623] transition-colors" data-idx={i}>
              <span>{item.q}</span>
              <span class="faq-caret text-[#F5A623] text-2xl flex-shrink-0 transition-transform duration-300">▾</span>
            </button>
            <div class="faq-answer overflow-hidden" style="max-height:0; transition:max-height 0.35s ease; background:#0F2A1D;">
              <p class="px-6 py-4 text-sm text-white/80 leading-relaxed">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOOKING FORM -->
  <section id="booking" class="py-20 px-4" style="background:#F8F7F4;">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-oswald text-5xl font-bold text-[#1A4731] uppercase mb-3">Join the Pack</h2>
        <p class="text-[#2D3A2A]">Tell us about your dog and we'll match them with the perfect adventure.</p>
      </div>
      <div id="v2-form-wrap" class="rounded-sm p-8 shadow-md" style="background:#fff; border:1px solid #ddd;">
        <form id="v2-booking-form" class="flex flex-col gap-5" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v2-owner-name" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Owner Name <span class="text-[#E87B3A]">*</span></label>
              <input id="v2-owner-name" name="ownerName" type="text" required autocomplete="name" placeholder="Your full name" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v2-pet-name" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Dog's Name <span class="text-[#E87B3A]">*</span></label>
              <input id="v2-pet-name" name="petName" type="text" required placeholder="Your dog's name" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v2-email" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Email <span class="text-[#E87B3A]">*</span></label>
              <input id="v2-email" name="email" type="email" required autocomplete="email" placeholder="you@email.com" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v2-phone" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Phone <span class="text-[#E87B3A]">*</span></label>
              <input id="v2-phone" name="phone" type="tel" required autocomplete="tel" placeholder="(720) 000-0000" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v2-breed" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Breed</label>
              <input id="v2-breed" name="breed" type="text" placeholder="e.g. Australian Shepherd" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v2-service" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Service <span class="text-[#E87B3A]">*</span></label>
              <select id="v2-service" name="service" required class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] rounded-sm">
                <option value="">Select a service…</option>
                {services.map((s) => <option value={s.name}>{s.name}</option>)}
              </select>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="v2-date" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Preferred Date <span class="text-[#E87B3A]">*</span></label>
            <input id="v2-date" name="date" type="date" required class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] rounded-sm" />
          </div>
          <div class="flex flex-col gap-1">
            <label for="v2-notes" class="text-sm font-semibold text-[#1A4731] uppercase tracking-wide font-oswald">Special Needs / Notes</label>
            <textarea id="v2-notes" name="notes" rows="4" placeholder="Fitness level, reactivity, dietary needs, anything we should know…" class="border border-gray-300 px-4 py-3 text-sm text-[#2D3A2A] placeholder:text-gray-400 rounded-sm resize-y"></textarea>
          </div>
          <button type="submit" class="btn-yellow text-base py-4 text-center rounded-sm font-oswald uppercase tracking-wider">
            Request Adventure
          </button>
        </form>
        <div id="v2-booking-success" class="hidden text-center py-12">
          <div class="text-6xl mb-4">⛰️</div>
          <h3 class="font-oswald text-3xl font-bold text-[#1A4731] uppercase mb-2">Adventure Booked!</h3>
          <p class="text-[#2D3A2A]">Thanks! We'll contact you within 24 hours to confirm your reservation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-20 px-4" style="background:#0F2A1D;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-oswald text-5xl font-bold text-white uppercase mb-3">Find Us</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-6">
          <div class="p-6" style="background:rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
            <h3 class="font-oswald text-xl font-bold text-white uppercase mb-4">Hours</h3>
            <table class="w-full text-sm text-white/75">
              <tbody>
                <tr class="border-b border-white/10"><td class="py-2 font-semibold">Monday – Friday</td><td class="py-2 text-right">{business.hours.weekdays}</td></tr>
                <tr class="border-b border-white/10"><td class="py-2 font-semibold">Saturday</td><td class="py-2 text-right">{business.hours.saturday}</td></tr>
                <tr><td class="py-2 font-semibold">Sunday</td><td class="py-2 text-right">{business.hours.sunday}</td></tr>
              </tbody>
            </table>
          </div>
          <div class="p-6 flex flex-col gap-4" style="background:rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);">
            <h3 class="font-oswald text-xl font-bold text-white uppercase mb-1">Contact</h3>
            <a href={`tel:${business.phone}`} class="flex items-center gap-3 text-white/75 hover:text-[#F5A623] transition-colors text-sm">📞 {business.phone}</a>
            <a href={`mailto:${business.email}`} class="flex items-center gap-3 text-white/75 hover:text-[#F5A623] transition-colors text-sm">✉️ {business.email}</a>
            <p class="text-sm text-white/75">📍 {business.address}</p>
            <p class="text-sm text-white/50">🚨 Emergency: {business.emergency}</p>
            <p class="text-xs text-white/40 mt-2">{business.license}</p>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12); min-height:300px;">
          <iframe
            title={`Map showing location of ${business.name}`}
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3055.4444!2d-105.28!3d40.0274!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876bed8b88b7706f%3A0x5c5e3b7e2eb3e152!2sBoulder%2C%20CO!5e0!3m2!1sen!2sus!4v1620000000000!5m2!1sen!2sus"
            width="100%" height="100%" style="border:0; min-height:300px;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background:#0F2A1D; border-top:2px solid #1A4731;" class="py-14 px-4 pb-16 md:pb-14">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-3 gap-10">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">⛰️</span>
          <span class="font-oswald text-xl font-bold text-white uppercase tracking-wider">{business.name}</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed">{business.description}</p>
        <p class="text-[#F5A623] text-xs mt-4">{business.instagram}</p>
      </div>
      <div>
        <h4 class="font-oswald text-base font-bold text-white uppercase tracking-wider mb-4">Explore</h4>
        <ul class="space-y-2 text-sm">
          {['#services', '#pricing', '#gallery', '#team', '#booking'].map((href, i) => (
            <li><a href={href} class="text-white/50 hover:text-[#F5A623] transition-colors uppercase font-oswald text-xs tracking-wider">{['Services','Pricing','Gallery','Team','Book Now'][i]}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-oswald text-base font-bold text-white uppercase tracking-wider mb-4">Reach Us</h4>
        <ul class="space-y-2 text-sm text-white/50">
          <li>{business.address}</li>
          <li><a href={`tel:${business.phone}`} class="hover:text-[#F5A623] transition-colors">{business.phone}</a></li>
          <li><a href={`mailto:${business.email}`} class="hover:text-[#F5A623] transition-colors">{business.email}</a></li>
        </ul>
        <p class="text-xs text-white/30 mt-6">© {new Date().getFullYear()} {business.name}</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE CTA BAR -->
  <div class="fixed bottom-0 left-0 right-0 z-50 flex md:hidden" style="height:56px;">
    <a href="tel:+17204438821" class="flex-1 flex items-center justify-center gap-2 text-white font-bold font-oswald uppercase tracking-wide text-sm" style="background:#0F2A1D;">
      <span>📞</span> (720) 443-8821
    </a>
    <a href="#booking" class="flex-1 flex items-center justify-center gap-2 text-[#1A4731] font-bold font-oswald uppercase tracking-wide text-sm" style="background:#F5A623;">
      Book a Hike
    </a>
  </div>

  <script>
    const today = new Date().toISOString().split('T')[0];
    document.querySelectorAll('input[type="date"]').forEach((el) => (el as HTMLInputElement).setAttribute('min', today));

    const btn = document.getElementById('v2-menu-btn');
    const menu = document.getElementById('v2-mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
      document.querySelectorAll('#v2-mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => menu.classList.add('hidden'));
      });
    }
    const form = document.getElementById('v2-booking-form') as HTMLFormElement | null;
    const success = document.getElementById('v2-booking-success');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.classList.add('hidden');
        if (success) success.classList.remove('hidden');
      });
    }
    // FAQ accordion
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const parent = trigger.parentElement;
        if (!parent) return;
        const answer = parent.querySelector('.faq-answer') as HTMLElement | null;
        const caret = trigger.querySelector('.faq-caret') as HTMLElement | null;
        const isOpen = trigger.classList.contains('faq-open');
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.classList.remove('faq-open');
          const p = t.parentElement;
          if (p) {
            const a = p.querySelector('.faq-answer') as HTMLElement | null;
            const c = t.querySelector('.faq-caret') as HTMLElement | null;
            if (a) a.style.maxHeight = '0';
            if (c) c.style.transform = 'rotate(0deg)';
          }
        });
        if (!isOpen && answer && caret) {
          trigger.classList.add('faq-open');
          answer.style.maxHeight = '500px';
          caret.style.transform = 'rotate(180deg)';
        }
      });
    });
  </script>
</BaseLayout>
