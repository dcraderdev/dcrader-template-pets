          <div class="bg-white border border-[#E2E8F0] rounded-md p-5">
            <h3 class="text-base font-bold text-[#0F172A] mb-4">Hours of Operation</h3>
            <table class="w-full text-sm text-[#334155]">
              <tbody>
                <tr class="border-b border-[#E2E8F0]"><td class="py-2 font-medium">Monday – Friday</td><td class="py-2 text-right text-[#0E7490] font-semibold">{business.hours.weekdays}</td></tr>
                <tr class="border-b border-[#E2E8F0]"><td class="py-2 font-medium">Saturday</td><td class="py-2 text-right text-[#0E7490] font-semibold">{business.hours.saturday}</td></tr>
