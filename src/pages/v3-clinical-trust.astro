        {testimonials.map((t) => (
          <div class="bg-white border border-[#E2E8F0] rounded-md p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center gap-2 mb-3">
              <div class="flex gap-0.5 text-[#F5A623]" aria-label={`${t.stars} out of 5 stars`}>
                {'★'.repeat(t.stars)}
              </div>
              <span class="text-xs bg-[#CCFBF1] text-[#0E7490] px-2 py-0.5 rounded-full font-semibold">Verified</span>
            </div>
            <blockquote class="text-sm text-[#334155] leading-relaxed mb-4 italic">"{t.text}"</blockquote>
            <div>
              <p class="font-bold text-[#0F172A] text-sm">{t.name}</p>
              <p class="text-xs text-[#64748B]">{t.breed} · {t.date}</p>
