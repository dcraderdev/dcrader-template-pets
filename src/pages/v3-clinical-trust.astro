---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v3/business';
import { services, packages } from '../data/v3/services';
import { gallery } from '../data/v3/gallery';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "telephone": business.phone,
  "email": business.email,
  "address": { "@type": "PostalAddress", "streetAddress": business.address },
  "url": "https://pets.dcrader.dev/v3-clinical-trust",
  "priceRange": "$$",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "184" },
  "openingHours": ["Mo-Fr 08:00-18:00", "Sa 09:00-17:00"],
});
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="https://images.unsplash.com/photo-1560743641-3914f2c45636?w=1200&h=630&fit=crop&q=80"
  schemaJson={schemaJson}
>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v3-banner" style="background:#0E7490;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative">
    <span>🩺 Now accepting new patients · Free intake assessment this month · (206) 514-7730</span>
    <button onclick="document.getElementById('v3-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    body { font-family: 'Inter', system-ui, sans-serif; background: #FFFFFF; color: #334155; }
    .font-inter { font-family: 'Inter', system-ui, sans-serif; }
    .btn-teal { background: #0E7490; color: #fff; border-radius: 6px; padding: 0.75rem 1.75rem; font-weight: 600; font-size: 0.875rem; transition: background 0.2s; display: inline-block; }
    .btn-teal:hover { background: #0c6478; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #0E7490; outline-offset: 2px; }
    .check-teal { color: #0E7490; font-weight: 700; }
    html { scroll-behavior: smooth; }
    section[id] { scroll-margin-top: 5rem; }
  </style>

  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-white border-b border-[#E2E8F0] shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl">🩺</span>
        <span class="font-semibold text-[#0E7490] text-lg">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a href="#services" class="text-[#334155] hover:text-[#0E7490] transition-colors">Services</a>
        <a href="#credentials" class="text-[#334155] hover:text-[#0E7490] transition-colors">Credentials</a>
        <a href="#pricing" class="text-[#334155] hover:text-[#0E7490] transition-colors">Pricing</a>
        <a href="#team" class="text-[#334155] hover:text-[#0E7490] transition-colors">Team</a>
        <a href="#contact" class="text-[#334155] hover:text-[#0E7490] transition-colors">Contact</a>
        <a href="#booking" class="btn-teal">Request Appointment</a>
      </div>
      <button id="v3-menu-btn" class="md:hidden text-[#0E7490] text-2xl" aria-label="Open menu">☰</button>
    </div>
    <div id="v3-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3 border-t border-[#E2E8F0]">
      <a href="#services" class="text-sm text-[#334155] font-medium py-2">Services</a>
      <a href="#credentials" class="text-sm text-[#334155] font-medium py-2">Credentials</a>
      <a href="#pricing" class="text-sm text-[#334155] font-medium py-2">Pricing</a>
      <a href="#team" class="text-sm text-[#334155] font-medium py-2">Team</a>
      <a href="#booking" class="btn-teal text-center">Request Appointment</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero" class="py-16 px-4" style="background:#F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-5 gap-12 items-center">
        <div class="md:col-span-3">
          <div class="inline-flex items-center gap-2 bg-[#CCFBF1] text-[#0E7490] text-xs font-semibold px-4 py-2 rounded-full mb-6">
            <span>✓</span> Veterinary-Supervised Grooming · Est. {business.founded}
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-[#0F172A] leading-tight mb-5">
            Grooming Built on<br/>
            <span class="text-[#0E7490]">Medical Standards.</span>
          </h1>
          <p class="text-[#334155] text-lg leading-relaxed mb-8 max-w-xl">{business.tagline}</p>
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="#booking" class="btn-teal text-base px-8 py-3">Request Appointment</a>
            <a href="#services" class="border border-[#E2E8F0] text-[#334155] px-8 py-3 rounded-md font-medium text-base hover:border-[#0E7490] hover:text-[#0E7490] transition-all">View Services</a>
          </div>
          <!-- Trust badges -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              { icon: '🏥', label: 'NAVTA Member · 2020–Present' },
              { icon: '✅', label: 'Fear Free Pro · Recertified 2025' },
              { icon: '📋', label: 'WA Lic. #VF-20208841' },
              { icon: '👩‍⚕️', label: 'DVM On-Staff' },
            ].map((b) => (
              <div class="bg-white border border-[#E2E8F0] rounded-md p-3 text-center shadow-sm">
                <div class="text-xl mb-1">{b.icon}</div>
                <p class="text-[#0E7490] text-xs font-semibold leading-tight">{b.label}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="md:col-span-2">
          <div class="rounded-lg overflow-hidden" style="border: 3px solid #0E7490;">
            <img
              src="https://images.unsplash.com/photo-1560743641-3914f2c45636?w=600&h=700&fit=crop&q=80"
              alt="Professional therapeutic grooming at Calm Coat Veterinary Grooming"
              class="w-full object-cover"
              style="height:420px;"
              fetchpriority="high"
            />
          </div>
          <div class="mt-3 p-3 bg-[#CCFBF1] rounded-md flex items-start gap-2">
            <span class="text-[#0E7490] font-bold text-lg">i</span>
            <p class="text-[#0E7490] text-xs leading-relaxed">Every appointment begins with a behavioral and coat assessment. No exceptions.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">What We Offer</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Our Services</h2>
        <p class="text-[#64748B] mt-2 max-w-lg">Every service is designed around the dog's comfort, not our convenience.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((s) => (
          <div class="flex gap-5 p-6 bg-white border border-[#E2E8F0] rounded-md hover:shadow-md transition-shadow" style="border-left: 4px solid #0E7490;">
            <div class="text-3xl flex-shrink-0 mt-1">{s.icon}</div>
            <div class="flex-grow">
              <div class="flex items-start justify-between gap-4 mb-2">
                <h3 class="text-lg font-bold text-[#0F172A]">{s.name}</h3>
                <span class="text-[#0E7490] font-bold text-sm whitespace-nowrap flex-shrink-0">{s.price}</span>
              </div>
              <p class="text-sm text-[#334155] leading-relaxed mb-3">{s.description}</p>
              <ul class="grid grid-cols-2 gap-1">
                {s.highlights.map((h) => (
                  <li class="text-xs text-[#64748B] flex items-center gap-1">
                    <span class="check-teal">✓</span> {h}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HEALTH & REQUIREMENTS -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="border border-[#E2E8F0] rounded-md overflow-hidden">
        <div class="px-6 py-4 border-b border-[#E2E8F0]" style="background:#F8FAFC;">
          <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-1">Policy</p>
          <h2 class="text-2xl font-bold text-[#0F172A]">Health &amp; Requirements</h2>
        </div>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-[#E2E8F0]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top w-48">Vaccination Requirements</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">Current <strong>Rabies</strong>, <strong>Bordetella</strong> (within 6 months), and <strong>DHPP/DA2PP</strong> required for all breeds. Records must be submitted prior to first appointment.</td>
            </tr>
            <tr class="border-b border-[#E2E8F0]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top">Temperament Assessment</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">All new dogs require a complimentary 30-minute behavioral meet &amp; greet before their first booking. This is non-negotiable.</td>
            </tr>
            <tr class="border-b border-[#E2E8F0]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top">Health on Appointment Day</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">Dogs must be flea/tick free, not in heat, and free of any contagious illness or active skin infection on the day of service.</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top">Emergency Protocol</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">24/7 veterinary partner is on call. Owners are contacted immediately — before any treatment decision is made. All incidents are documented in the patient record.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CREDENTIALS -->
  <section id="credentials" class="py-16 px-4" style="background:#F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Our Standards</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Credentials & Certifications</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {[
          '🏥 NAVTA Member Facility',
          '✅ Fear Free Certified Professional',
          '👩‍⚕️ Veterinary-Supervised',
          '📋 WA Licensed #VF-20208841',
          '🎓 NCMG Certified Master Groomer',
          '🌿 Fear Free Grooming Specialist',
          '🦴 Orthopedic Handling Trained',
          '💉 Partner Veterinary Clinic On-Call',
          '📸 Before/After Documentation',
          '🔬 DVM-Reviewed Protocols',
          '🚫 Zero Cage Drying',
          '⭐ Fear Free Shelter Specialist',
        ].map((cred) => (
          <div class="flex items-center gap-2 bg-white border border-[#E2E8F0] rounded-full px-4 py-2 text-sm font-medium text-[#334155] shadow-sm">
            {cred}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <section class="py-10 px-4 bg-white border-y border-[#E2E8F0]">
    <div class="max-w-5xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
      {[
        { n: '2,300+', label: 'Appointments Completed' },
        { n: '4.9 ★', label: '184 Verified Reviews' },
        { n: '0', label: 'Cage Drying — Ever' },
        { n: '100%', label: 'Fear-Free Protocols' },
      ].map((s) => (
        <div>
          <div class="text-3xl font-bold text-[#0E7490] mb-1">{s.n}</div>
          <p class="text-[#64748B] text-xs tracking-wider uppercase">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Plans</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Pricing</h2>
      </div>
      <div class="flex flex-col gap-5">
        {packages.map((pkg) => (
          <div class={`flex flex-col sm:flex-row gap-6 items-start sm:items-center p-6 border rounded-md ${pkg.featured ? 'border-[#0E7490] bg-[#F8FAFC]' : 'border-[#E2E8F0] bg-white'}`}>
            {pkg.featured && <div class="bg-[#0E7490] text-white text-xs font-semibold px-3 py-1 rounded-full self-start sm:hidden">Most Popular</div>}
            <div class="sm:w-48 flex-shrink-0">
              <div class="flex items-center gap-2 mb-1">
                {pkg.featured && <span class="hidden sm:inline bg-[#0E7490] text-white text-xs font-semibold px-2 py-0.5 rounded-full">Popular</span>}
              </div>
              <h3 class="text-xl font-bold text-[#0F172A] mb-1">{pkg.name}</h3>
              <p class="text-sm text-[#64748B]">{pkg.period}</p>
              <p class="text-3xl font-bold text-[#0E7490] mt-2">{pkg.price}</p>
            </div>
            <div class="flex-grow border-t sm:border-t-0 sm:border-l border-[#E2E8F0] pt-4 sm:pt-0 sm:pl-6">
              <p class="text-sm text-[#334155] mb-3">{pkg.description}</p>
              <ul class="grid sm:grid-cols-2 gap-2">
                {pkg.features.map((f) => (
                  <li class="text-sm text-[#334155] flex items-center gap-2">
                    <span class="check-teal">✓</span> {f}
                  </li>
                ))}
              </ul>
            </div>
            <div class="sm:w-40 flex-shrink-0">
              <a href="#booking" class={`btn-teal text-sm py-2 px-5 w-full text-center block ${pkg.featured ? 'bg-[#0E7490]' : 'bg-[#0D9488]'}`}>
                Get Started
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="py-16 px-4" style="background:#F8FAFC;">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Our Studio</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Gallery</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {gallery.map((img) => (
          <div class="overflow-hidden shadow-sm hover:shadow-md transition-shadow" style="aspect-ratio: 4/3;">
            <img src={img.url} alt={img.alt} loading="lazy" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-500" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BEFORE & AFTER -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Results</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Before & After</h2>
        <p class="text-[#64748B] mt-2 max-w-lg">Every visit documented. Here's what fear-free, evidence-based grooming actually looks like.</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          {
            before: 'Tangled, matted coat — 8 months ungroomed. Dog refused any handling.',
            after: 'Full dematting over two gentle sessions. Coat restored without shaving.',
            breed: 'Golden Doodle · 4 yrs',
            tag: 'Dematting',
          },
          {
            before: 'Severe anxiety — past groomer required muzzle, dog couldn\'t be finished.',
            after: 'Completed full groom using desensitization protocol. No muzzle needed.',
            breed: 'Shih Tzu · 6 yrs',
            tag: 'Anxiety Case',
          },
          {
            before: 'Double coat blowout — 40% undercoat retained post-summer. Hot spots forming.',
            after: 'Full deshed treatment. 2.5 lbs of undercoat removed. Hot spots resolved.',
            breed: 'Siberian Husky · 3 yrs',
            tag: 'Double Coat',
          },
        ].map((c) => (
          <div class="border border-[#E2E8F0] rounded-md overflow-hidden">
            <div class="px-4 py-2 text-xs font-semibold uppercase tracking-wide text-white" style="background:#0E7490;">{c.tag}</div>
            <div class="p-5 flex flex-col gap-4">
              <div>
                <p class="text-[#94A3B8] text-xs font-semibold uppercase tracking-wider mb-1">Before</p>
                <p class="text-sm text-[#334155] leading-relaxed">{c.before}</p>
              </div>
              <div class="h-px bg-[#E2E8F0]"></div>
              <div>
                <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-wider mb-1">After</p>
                <p class="text-sm text-[#334155] leading-relaxed">{c.after}</p>
              </div>
              <p class="text-xs text-[#94A3B8] mt-1">{c.breed}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">The Process</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">How It Works</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold text-white" style="background:#0E7490;">1</div>
          <h3 class="text-lg font-bold text-[#0F172A]">Request Intake</h3>
          <p class="text-sm text-[#334155] leading-relaxed">Submit the online intake form with your dog's full medical history, prior grooming experiences, and any known behavioral triggers.</p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold text-white" style="background:#0D9488;">2</div>
          <h3 class="text-lg font-bold text-[#0F172A]">Behavioral Assessment</h3>
          <p class="text-sm text-[#334155] leading-relaxed">Dr. Santos or a certified technician conducts a 30-minute behavioral evaluation. We identify sensitivities and design a care protocol accordingly.</p>
        </div>
        <div class="flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold text-white" style="background:#0E7490;">3</div>
          <h3 class="text-lg font-bold text-[#0F172A]">Tailored First Appointment</h3>
          <p class="text-sm text-[#334155] leading-relaxed">Your dog's first service is paced to their comfort level. Every step is documented. You receive a full report at pickup.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DVM QUOTE -->
  <section style="background:#F8FAFC; border-top:1px solid #E2E8F0; border-bottom:1px solid #E2E8F0;" class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-5 gap-10 items-center">
        <div class="md:col-span-2">
          <img
            src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&h=500&fit=crop&q=80"
            alt="Dr. Elena Santos, DVM, Medical Director at Calm Coat Veterinary Grooming"
            class="w-full object-cover"
            style="border-top: 4px solid #0E7490; max-height: 360px;"
          />
        </div>
        <div class="md:col-span-3">
          <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-3">Medical Director</p>
          <h2 class="text-2xl font-bold text-[#0F172A] mb-1">Dr. Elena Santos, DVM</h2>
          <p class="text-[#0E7490] text-sm font-semibold mb-6">Fear Free Certified · 14 Years Clinical Experience · WA Licensed</p>
          <blockquote class="border-l-4 border-[#0E7490] pl-6 mb-6">
            <p class="text-[#334155] text-lg italic leading-relaxed">"The grooming table is a medical interaction. Dogs don't understand why they're being handled — they only know if it feels safe. Our protocols exist to make every second feel safe. That's not a luxury. That's the baseline."</p>
          </blockquote>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[#CCFBF1] text-[#0E7490] px-3 py-1.5 text-xs font-semibold rounded-full">DVM — Washington State University</span>
            <span class="bg-[#CCFBF1] text-[#0E7490] px-3 py-1.5 text-xs font-semibold rounded-full">Fear Free Certified Professional</span>
            <span class="bg-[#CCFBF1] text-[#0E7490] px-3 py-1.5 text-xs font-semibold rounded-full">NAVTA Member</span>
            <span class="bg-[#CCFBF1] text-[#0E7490] px-3 py-1.5 text-xs font-semibold rounded-full">Veterinary Behaviorist Network</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">The Experts</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Our Team</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map((member) => (
          <div class="border border-[#E2E8F0] rounded-md overflow-hidden hover:shadow-md transition-shadow">
            <div class="h-2 bg-[#0E7490]"></div>
            <img src={member.photo} alt={`Photo of ${member.name}, ${member.role}`} class="w-full h-48 object-cover" />
            <div class="p-5">
              <h3 class="text-lg font-bold text-[#0F172A] mb-0.5">{member.name}</h3>
              <p class="text-[#0E7490] text-sm font-semibold mb-3">{member.role}</p>
              <p class="text-sm text-[#334155] leading-relaxed mb-4">{member.bio}</p>
              <ul class="space-y-1">
                {member.certifications.map((cert) => (
                  <li class="text-xs text-[#64748B] flex items-center gap-2">
                    <span class="check-teal">✓</span> {cert}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-16 px-4" style="background:#F8FAFC;">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Patient Reviews</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">What Our Clients Say</h2>
      </div>
