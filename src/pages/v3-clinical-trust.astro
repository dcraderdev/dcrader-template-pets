      <div class="text-center mt-10">
        <a href="#" class="inline-flex items-center gap-2 text-sm font-medium text-[#334155] hover:text-[#0E7490] transition-colors">
          <span class="text-[#F5A623]">★★★★★</span> Read all 184 verified reviews on Google
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4" style="background:#F8FAFC;">
    <div class="max-w-3xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Patient FAQs</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Frequently Asked</h2>
      </div>
      <div class="flex flex-col gap-2" id="v3-faq">
        {[
          { q: 'My dog has bitten groomers before. Can you help?', a: 'Possibly. We schedule a free behavioral consultation with Dr. Santos first. We never guarantee outcomes but we\'ve successfully groomed many bite-risk dogs.' },
          { q: 'Do you use muzzles?', a: 'Only if the dog and owner agree in advance, and only basket muzzles that allow panting. Never as restraint.' },
          { q: 'How long does a full groom take?', a: '2–3 hours for anxious dogs. We don\'t rush. You\'ll get a time window and a text when we\'re wrapping up.' },
          { q: 'Can I stay during the appointment?', a: 'For the first visit, yes. After that, dog-only is typically better—they\'re calmer without parental anxiety in the room.' },
          { q: 'Do you groom cats?', a: 'Not at this time. Dogs only.' },
        ].map((item, i) => (
          <div class="bg-white border border-[#E2E8F0] rounded-md overflow-hidden hover:shadow-sm transition-shadow">
            <button class="faq-trigger w-full text-left px-6 py-4 flex items-center justify-between gap-4 text-sm font-semibold text-[#0F172A] hover:text-[#0E7490] transition-colors" data-idx={i}>
              <span>{item.q}</span>
              <span class="faq-caret text-[#0E7490] text-lg flex-shrink-0 transition-transform duration-300 font-bold">+</span>
            </button>
            <div class="faq-answer overflow-hidden" style="max-height:0; transition:max-height 0.35s ease;">
              <p class="px-6 pb-4 text-sm text-[#334155] leading-relaxed border-t border-[#E2E8F0] pt-3">{item.a}</p>
            </div>
          </div>
