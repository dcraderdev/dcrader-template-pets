---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import GroomingGrid from '../components/pets/GroomingGrid.astro';
import { business, team, testimonials } from '../data/v3/business';
import { services, packages } from '../data/v3/services';
import { gallery } from '../data/v3/gallery';
import { img } from '../data/images';
const heroImg = img('1560743641');

// Build hero tiles by pairing services with photography from the gallery dataset.
const heroTiles = [
  { src: img('1560743641'), label: services[0]?.name ?? 'Therapeutic Bath', sub: 'Vet-approved shampoos', price: services[0]?.price, href: '#services' },
  { src: img('1561037404'), label: services[1]?.name ?? 'Anxiety Specialist', sub: 'Extended gentle session', price: services[1]?.price, href: '#services' },
  { src: img('1518717758536'), label: services[2]?.name ?? 'Medical Coat Tx', sub: 'DVM-prescribed protocol', price: services[2]?.price, href: '#services' },
  { src: img('1560807707'), label: 'Brachycephalic Care', sub: 'Flat-face certified handling', price: 'From $65', href: '#services' },
  { src: img('1510771463146'), label: services[3]?.name ?? 'Nail Grinding', sub: 'Dremel option · no restraint', price: services[3]?.price, href: '#services' },
];

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "telephone": business.phone,
  "email": business.email,
  "address": { "@type": "PostalAddress", "streetAddress": business.address },
  "url": "https://dcrader-template-pets.vercel.app/v3-clinical-trust",
  "priceRange": "$$",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "184" },
  "openingHours": ["Mo-Fr 08:00-18:00", "Sa 09:00-17:00"],
});
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="/images/photo-1560743641-3914f2c45636-1600.webp"
  heroImage={heroImg.src}
  schemaJson={schemaJson}
>

  <style>
    body { font-family: 'Inter', system-ui, sans-serif; background: #FFFFFF; color: #334155; }
    .font-inter { font-family: 'Inter', system-ui, sans-serif; }
    .btn-teal { background: #0E7490; color: #fff; border-radius: 6px; padding: 0.75rem 1.75rem; font-weight: 600; font-size: 0.875rem; transition: background 0.2s; display: inline-block; }
    .btn-teal:hover { background: #0c6478; }
    .btn-outline { border: 1.5px solid #E2E8F0; color: #334155; border-radius: 6px; padding: 0.75rem 1.75rem; font-weight: 600; font-size: 0.875rem; transition: all 0.2s; display: inline-block; }
    .btn-outline:hover { border-color: #0E7490; color: #0E7490; }
    input:focus, select:focus, textarea:focus { outline: 2px solid #0E7490; outline-offset: 2px; }
    .check-teal { color: #0E7490; font-weight: 700; }
    html { scroll-behavior: smooth; }
    section[id] { scroll-margin-top: 5rem; }
    .step-line { position: absolute; top: 50%; left: calc(50% + 1.5rem); right: calc(-50% + 1.5rem); height: 1px; background: #CBD5E1; transform: translateY(-50%); }
  </style>

  <!-- CREDENTIAL STRIP (non-dismissable) -->
  <div style="background:#0E7490;" class="w-full py-2 px-4">
    <p class="text-white text-xs text-center tracking-wide font-medium leading-relaxed">
      🏥 NAVTA Member Since 2020 &nbsp;·&nbsp; ✅ Fear Free Certified &nbsp;·&nbsp; 📋 WA Lic. #VF-20208841 &nbsp;·&nbsp; 🩺 DVM On-Staff &nbsp;·&nbsp; 🛡️ AAHA Practice Partner
    </p>
  </div>

  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-white border-b border-[#E2E8F0] shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl">🩺</span>
        <span class="font-semibold text-[#0E7490] text-lg">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a href="#services" class="text-[#334155] hover:text-[#0E7490] transition-colors">Services</a>
        <a href="#process" class="text-[#334155] hover:text-[#0E7490] transition-colors">Process</a>
        <a href="#pricing" class="text-[#334155] hover:text-[#0E7490] transition-colors">Pricing</a>
        <a href="#team" class="text-[#334155] hover:text-[#0E7490] transition-colors">Team</a>
        <a href="#contact" class="text-[#334155] hover:text-[#0E7490] transition-colors">Contact</a>
        <a href="#booking" class="btn-teal">Request Appointment</a>
      </div>
      <button id="v3-menu-btn" class="md:hidden text-[#0E7490] text-2xl" aria-label="Open menu">☰</button>
    </div>
    <div id="v3-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3 border-t border-[#E2E8F0]">
      <a href="#services" class="text-sm text-[#334155] font-medium py-2">Services</a>
      <a href="#process" class="text-sm text-[#334155] font-medium py-2">Process</a>
      <a href="#pricing" class="text-sm text-[#334155] font-medium py-2">Pricing</a>
      <a href="#team" class="text-sm text-[#334155] font-medium py-2">Team</a>
      <a href="#contact" class="text-sm text-[#334155] font-medium py-2">Contact</a>
      <a href="#booking" class="btn-teal text-center">Request Appointment</a>
    </div>
  </nav>

  <!-- HERO — GROOMING SERVICES IMAGE GRID -->
  <GroomingGrid
    bg="#F0FAFA"
    fg="#0F172A"
    accent="#0E7490"
    muted="#64748B"
    cardBg="#FFFFFF"
    eyebrow={`Veterinary Grooming · Seattle, WA · Fremont · Est. ${business.founded}`}
    headline="Grooming Built on Medical Standards"
    subhead="Browse our specialty services — each shaped around fear-free protocols, low-stress handling, and full DVM oversight. Tap any tile to learn more."
    tiles={heroTiles}
    fontHead="'Inter', system-ui, sans-serif"
    fontBody="'Inter', system-ui, sans-serif"
  />

  <!-- CERTIFICATIONS & ACCREDITATIONS -->
  <section class="bg-white border-t border-b border-[#E2E8F0] py-10 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-baseline justify-between border-b border-[#E2E8F0] pb-3 mb-6">
        <div>
          <p class="text-[#0E7490] text-[10px] font-semibold uppercase tracking-[0.22em]">§ Credentials Registry</p>
          <h2 class="text-base font-semibold text-[#0F172A] mt-1">Active Certifications & Professional Memberships</h2>
        </div>
        <p class="text-[#94A3B8] text-[10px] uppercase tracking-wider hidden sm:block">Verified: Q2 2026</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-5">
        {[
          { abbr: 'DVM', org: 'Doctor of Veterinary Medicine', auth: 'Washington State Veterinary Board', id: 'WA-VET-#4421', exp: 'Active' },
          { abbr: 'CAAB', org: 'Certified Applied Animal Behaviorist', auth: 'Animal Behavior Society', id: 'CAAB-#0918', exp: 'Renewed 2026' },
          { abbr: 'NCMG', org: 'Nationally Certified Master Groomer', auth: 'National Dog Groomers Assoc.', id: 'NCMG-#3187', exp: 'Active' },
          { abbr: 'CGC', org: 'AKC Canine Good Citizen Evaluator', auth: 'American Kennel Club', id: 'CGC-EV-#11042', exp: 'Active' },
          { abbr: 'FFCP', org: 'Fear Free Certified Professional', auth: 'Fear Free, LLC', id: 'FFCP-#27514', exp: 'Renewed 2026' },
          { abbr: 'RVT', org: 'Registered Veterinary Technician', auth: 'WA Veterinary Tech. Assoc.', id: 'RVT-WA-#8826', exp: 'Active' },
          { abbr: 'CPR1', org: 'Pet First Aid & CPR Instructor', auth: 'Pet Tech / American Red Cross', id: 'PT-INST-#1166', exp: 'Active' },
          { abbr: 'LSH', org: 'Low Stress Handling® Silver', auth: 'CattleDog Publishing / Yin Inst.', id: 'LSH-S-#04412', exp: 'Active' },
        ].map((c) => (
          <div class="flex items-start gap-3 border-l-2 border-[#0E7490] pl-3 py-1">
            <div class="bg-[#CCFBF1] text-[#0E7490] font-semibold text-[10px] tracking-wider px-2 py-1 leading-none rounded-sm whitespace-nowrap mt-0.5">{c.abbr}</div>
            <div class="min-w-0">
              <p class="text-[#0F172A] text-xs font-semibold leading-snug">{c.org}</p>
              <p class="text-[#64748B] text-[11px] leading-snug">{c.auth}</p>
              <p class="text-[#94A3B8] text-[10px] mt-0.5 font-mono tracking-tight">{c.id} · {c.exp}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-[#94A3B8] text-[11px] mt-7 leading-relaxed max-w-3xl">
        All credentials independently verified through issuing bodies. Hard copies are available for client review at intake. Calm Coat maintains continuing education hours exceeding minimum requirements for every active certification on file.
      </p>
    </div>
  </section>

  <!-- SERVICES — DATA TABLE -->
  <section id="services" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Procedures</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Services &amp; Procedures</h2>
        <p class="text-[#64748B] mt-2 max-w-lg text-sm">All procedures are conducted under veterinary-supervised protocols. Pricing reflects individual assessment outcomes.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b-2 border-[#0E7490] text-left">
              <th class="py-3 px-4 text-xs font-semibold uppercase tracking-wide text-[#0E7490]">Service</th>
              <th class="py-3 px-4 text-xs font-semibold uppercase tracking-wide text-[#0E7490]">Duration</th>
              <th class="py-3 px-4 text-xs font-semibold uppercase tracking-wide text-[#0E7490]">From</th>
              <th class="py-3 px-4 text-xs font-semibold uppercase tracking-wide text-[#0E7490] hidden md:table-cell">Key Inclusions</th>
            </tr>
          </thead>
          <tbody>
            {services.map((s, i) => (
              <tr class={`border-b border-[#E2E8F0] ${i % 2 === 0 ? 'bg-white' : 'bg-[#F8FAFC]'}`}>
                <td class="py-4 px-4 border-l-4 border-[#0E7490]">
                  <div class="font-semibold text-[#0F172A]">{s.name}</div>
                  <div class="text-sm text-[#334155] mt-1">{s.description}</div>
                </td>
                <td class="py-4 px-4 text-sm text-[#334155] whitespace-nowrap">60–90 min</td>
                <td class="py-4 px-4 whitespace-nowrap">
                  <span class="bg-[#CCFBF1] text-[#0E7490] text-sm font-semibold px-2 py-1 rounded">{s.price}</span>
                </td>
                <td class="py-4 px-4 hidden md:table-cell">
                  <ul class="text-xs text-[#334155] space-y-0.5">
                    {s.highlights.map((h) => <li>&bull; {h}</li>)}
                  </ul>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <!-- Mobile card fallback hint -->
      <p class="text-xs text-[#94A3B8] mt-3 md:hidden">Scroll right to view all columns, or request a full service list by phone.</p>
    </div>
  </section>

  <!-- CLINICAL INTAKE PROCESS -->
  <section id="process" class="py-16 px-4 bg-[#F0FAFA]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Onboarding Protocol</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Patient Intake Process</h2>
        <p class="text-[#64748B] mt-2 text-sm max-w-lg">All new patients are enrolled through a structured intake procedure before any grooming services are scheduled.</p>
      </div>
      <!-- Steps: horizontal with connecting line -->
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-8 sm:gap-4">
        {[
          {
            n: '01',
            title: 'Submit Medical History',
            desc: 'Complete the online intake form with vaccination records, prior grooming history, behavioral triggers, and current medications.',
          },
          {
            n: '02',
            title: 'Behavior & Coat Assessment',
            desc: '30-minute DVM evaluation conducted by Dr. Santos or a certified RVT. All findings are documented in the patient file.',
          },
          {
            n: '03',
            title: 'Custom Grooming Protocol',
            desc: 'A grooming plan is drafted and signed off by Dr. Santos before any service is scheduled. Protocol is filed in the patient record.',
          },
          {
            n: '04',
            title: 'Appointment Confirmation',
            desc: 'We confirm your appointment within 4 business hours via email. All required documents must be received prior to confirmation.',
          },
        ].map((step, i) => (
          <div class="flex flex-col gap-3">
            <div class="flex sm:flex-col gap-4 sm:gap-3 items-start">
              <div class="flex-shrink-0 bg-[#0E7490] text-white text-xs font-bold px-3 py-1.5 rounded tracking-widest">{step.n}</div>
              {i < 3 && (
                <div class="hidden sm:block h-px bg-[#CBD5E1] flex-grow mt-3" style="display:none;"></div>
              )}
            </div>
            <h3 class="text-base font-bold text-[#0F172A]">{step.title}</h3>
            <p class="text-sm text-[#334155] leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
      <!-- Connecting line for desktop -->
      <div class="hidden sm:flex items-center gap-0 mt-2 -mt-[calc(100%-3rem)] pointer-events-none" aria-hidden="true"></div>
    </div>
  </section>

  <!-- HEALTH & REQUIREMENTS -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="border border-[#E2E8F0] rounded-md overflow-hidden">
        <div class="px-6 py-5 border-b border-[#E2E8F0]" style="background:#F8FAFC;">
          <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-1">Facility Policy</p>
          <h2 class="text-2xl font-bold text-[#0F172A]">Health &amp; Admission Requirements</h2>
          <p class="text-[#64748B] text-sm mt-1">The following requirements apply to all patients. Non-compliance will result in appointment cancellation.</p>
        </div>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-[#E2E8F0]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top w-48 whitespace-nowrap border-l-4 border-[#0E7490]">Vaccination Requirements</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">Current <strong>Rabies</strong>, <strong>Bordetella</strong> (within 6 months), and <strong>DHPP/DA2PP</strong> required for all breeds. Records must be submitted via the intake portal prior to the first appointment. No exceptions.</td>
            </tr>
            <tr class="border-b border-[#E2E8F0] bg-[#F8FAFC]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top whitespace-nowrap border-l-4 border-[#0E7490]">Temperament Assessment</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">All new patients require a 30-minute behavioral consultation before their first service. This assessment determines protocol suitability and is required for scheduling. It is non-negotiable.</td>
            </tr>
            <tr class="border-b border-[#E2E8F0]">
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top whitespace-nowrap border-l-4 border-[#0E7490]">Day-of-Service Health</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">Patients must be free of external parasites (fleas/ticks), not in active heat, and clear of any contagious illness or open skin lesions on the day of service. Appointment will be declined if conditions are unmet.</td>
            </tr>
            <tr>
              <td class="px-6 py-4 font-semibold text-[#0F172A] align-top whitespace-nowrap border-l-4 border-[#0E7490]">Emergency Protocol</td>
              <td class="px-6 py-4 text-[#334155] leading-relaxed">A 24/7 veterinary partner is on call throughout every appointment. Guardians are contacted immediately — before any treatment decision is made. All incidents are documented in the patient record and shared with the guardian's primary veterinarian upon request.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- PRICING — COMPARISON TABLE -->
  <section id="pricing" class="py-16 px-4 bg-[#F0FAFA]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Packages</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Service Packages</h2>
        <p class="text-[#64748B] mt-2 text-sm max-w-lg">All rates are per visit unless otherwise noted. Final pricing confirmed following the intake assessment.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse bg-white border border-[#E2E8F0] rounded-md overflow-hidden text-sm">
          <thead>
            <tr class="border-b-2 border-[#0E7490] bg-[#F8FAFC]">
              <th class="py-3 px-5 text-xs font-semibold uppercase tracking-wide text-[#0E7490] text-left">Package</th>
              <th class="py-3 px-5 text-xs font-semibold uppercase tracking-wide text-[#0E7490] text-left">Frequency</th>
              <th class="py-3 px-5 text-xs font-semibold uppercase tracking-wide text-[#0E7490] text-left">Rate</th>
              <th class="py-3 px-5 text-xs font-semibold uppercase tracking-wide text-[#0E7490] text-left hidden md:table-cell">Includes</th>
              <th class="py-3 px-5 text-xs font-semibold uppercase tracking-wide text-[#0E7490] text-right"></th>
            </tr>
          </thead>
          <tbody>
            {packages.map((pkg, i) => (
              <tr class={`border-b border-[#E2E8F0] ${pkg.featured ? 'bg-[#F0FAFA]' : i % 2 === 0 ? 'bg-white' : 'bg-[#F8FAFC]'}`}>
                <td class={`py-4 px-5 border-l-4 ${pkg.featured ? 'border-[#0E7490]' : 'border-transparent'}`}>
                  <div class="flex items-center gap-2">
                    <span class="font-bold text-[#0F172A]">{pkg.name}</span>
                    {pkg.featured && <span class="bg-[#0E7490] text-white text-xs font-semibold px-2 py-0.5 rounded">Recommended</span>}
                  </div>
                  <p class="text-xs text-[#64748B] mt-0.5">{pkg.description}</p>
                </td>
                <td class="py-4 px-5 text-[#334155] whitespace-nowrap">{pkg.period}</td>
                <td class="py-4 px-5 whitespace-nowrap">
                  <span class={`text-lg font-bold ${pkg.featured ? 'text-[#0E7490]' : 'text-[#0F172A]'}`}>{pkg.price}</span>
                </td>
                <td class="py-4 px-5 hidden md:table-cell">
                  <ul class="text-xs text-[#334155] space-y-0.5">
                    {pkg.features.slice(0, 4).map((f) => <li class="flex items-start gap-1"><span class="text-[#0E7490] font-bold mt-0.5">&#10003;</span> {f}</li>)}
                    {pkg.features.length > 4 && <li class="text-[#94A3B8]">+{pkg.features.length - 4} more</li>}
                  </ul>
                </td>
                <td class="py-4 px-5 text-right">
                  <a href="#booking" class="btn-teal text-xs py-2 px-4 whitespace-nowrap">Select</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-[#94A3B8] mt-4">All prices listed in USD. Sales tax applicable. Contact us for multi-patient household rates.</p>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="py-16 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Facility</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Studio Gallery</h2>
        <p class="text-[#64748B] mt-2 text-sm">Our studio is designed to clinical standards: single-patient-at-a-time throughput, non-slip surfaces, temperature-controlled, no cage drying.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
        {gallery.map((img) => (
          <div class="overflow-hidden bg-[#F8FAFC]" style="aspect-ratio: 4/3;">
            <Picture src={img.src} alt={img.alt} widths={[300, 500, 700]} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw" formats={['avif','webp']} fallbackFormat="webp" quality={72} loading="lazy" decoding="async" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-500" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM — PROFESSIONAL STAFF DIRECTORY -->
  <section id="team" class="py-16 px-4 bg-[#F0FAFA]">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10 border-b border-[#E2E8F0] pb-6">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Clinical Staff</p>
        <h2 class="text-3xl font-bold text-[#0F172A]">Staff Directory</h2>
      </div>
      <div class="flex flex-col gap-5">
        {team.map((member) => (
          <div class="bg-white border border-[#E2E8F0] rounded-md overflow-hidden flex flex-col sm:flex-row">
            <div class="sm:w-40 flex-shrink-0">
              <Picture
                src={member.photo}
                alt={`${member.name}, ${member.role}`}
                widths={[200, 400]}
                sizes="160px"
                formats={['avif','webp']}
                fallbackFormat="webp"
                quality={75}
                loading="lazy"
                decoding="async"
                class="w-full h-48 sm:h-full object-cover"
              />
            </div>
            <div class="flex-grow p-6 border-t sm:border-t-0 sm:border-l border-[#E2E8F0]">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-lg font-bold text-[#0F172A]">{member.name}</h3>
                  <p class="text-[#0E7490] text-sm font-semibold">{member.role}</p>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {member.certifications.slice(0, 2).map((cert) => (
                    <span class="border border-[#0E7490] text-[#0E7490] text-xs font-medium px-2 py-0.5 rounded">{cert}</span>
                  ))}
                </div>
              </div>
              <p class="text-sm text-[#334155] leading-relaxed mb-3">{member.bio}</p>
              {member.certifications.length > 2 && (
                <div class="flex flex-wrap gap-1.5">
                  {member.certifications.slice(2).map((cert) => (
                    <span class="border border-[#CBD5E1] text-[#64748B] text-xs px-2 py-0.5 rounded">{cert}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

