  <!-- BOOKING FORM -->
  <section id="booking" class="py-16 px-4 bg-white">
    <div class="max-w-2xl mx-auto">
      <div class="mb-10">
        <p class="text-[#0E7490] text-xs font-semibold uppercase tracking-widest mb-2">Scheduling</p>
        <h2 class="text-3xl font-bold text-[#0F172A] mb-2">Request Appointment</h2>
        <p class="text-[#334155] text-sm">All new patients begin with a 30-minute intake assessment. Fill out the form and we'll confirm within 24 hours.</p>
      </div>
      <div id="v3-form-wrap" class="border border-[#E2E8F0] rounded-md p-8 shadow-sm">
        <form id="v3-booking-form" class="flex flex-col gap-5" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v3-owner-name" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Owner Name <span class="text-red-500">*</span></label>
              <input id="v3-owner-name" name="ownerName" type="text" required autocomplete="name" placeholder="Your full name" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8]" />
              <p class="text-xs text-[#94A3B8]">Legal name for records</p>
            </div>
            <div class="flex flex-col gap-1">
              <label for="v3-pet-name" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Pet Name <span class="text-red-500">*</span></label>
              <input id="v3-pet-name" name="petName" type="text" required placeholder="Your dog's name" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8]" />
              <p class="text-xs text-[#94A3B8]">As it appears on records</p>
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v3-email" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Email <span class="text-red-500">*</span></label>
              <input id="v3-email" name="email" type="email" required autocomplete="email" placeholder="you@email.com" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v3-phone" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Phone <span class="text-red-500">*</span></label>
              <input id="v3-phone" name="phone" type="tel" required autocomplete="tel" placeholder="(206) 000-0000" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v3-breed" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Breed</label>
              <input id="v3-breed" name="breed" type="text" placeholder="e.g. Standard Poodle" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v3-service" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Service Type <span class="text-red-500">*</span></label>
              <select id="v3-service" name="service" required class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A]">
                <option value="">Select a service…</option>
                {services.map((s) => <option value={s.name}>{s.name}</option>)}
              </select>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="v3-date" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Preferred Date <span class="text-red-500">*</span></label>
            <input id="v3-date" name="date" type="date" required class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A]" />
          </div>
          <div class="flex flex-col gap-1">
            <label for="v3-notes" class="text-xs font-semibold text-[#0F172A] uppercase tracking-wide">Medical / Behavioral Notes</label>
            <textarea id="v3-notes" name="notes" rows="4" placeholder="Known anxiety triggers, skin conditions, medications, mobility limitations, prior grooming incidents…" class="border border-[#E2E8F0] rounded-md px-4 py-3 text-sm text-[#0F172A] placeholder:text-[#94A3B8] resize-y"></textarea>
            <p class="text-xs text-[#94A3B8]">This information is kept confidential and shared only with your care team</p>
          </div>
          <button type="submit" class="btn-teal text-sm py-3 w-full text-center">Submit Appointment Request</button>
        </form>
        <div id="v3-booking-success" class="hidden text-center py-12">
          <div class="text-5xl mb-4">✅</div>
          <h3 class="text-2xl font-bold text-[#0F172A] mb-2">Request Received</h3>
          <p class="text-[#334155] text-sm">Thanks! We'll contact you within 24 hours to confirm your appointment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
