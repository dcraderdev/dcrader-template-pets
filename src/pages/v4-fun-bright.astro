---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v4/business';
import { services, packages } from '../data/v4/services';
import { gallery } from '../data/v4/gallery';
---
<BaseLayout title={`${business.name} — ${business.tagline}`} description={business.description}>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v4-banner" style="background:#F97316;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative font-bold">
    <span>🎉 New pups! First daycare day just $10 — Sniff &amp; Snuggle Intro Special · Book today!</span>
    <button onclick="document.getElementById('v4-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    body { font-family: 'Nunito', sans-serif; background: #FFFBF7; color: #475569; }
    .font-fredoka { font-family: 'Fredoka One', cursive; }
    .hero-clip { clip-path: polygon(0 0, 100% 0, 100% 90%, 0 100%); }
    .btn-coral { background: #F97316; color: #fff; border-radius: 999px; padding: 0.85rem 2rem; font-weight: 800; transition: all 0.2s; display: inline-block; }
    .btn-coral:hover { background: #ea6a0a; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(249,115,22,0.35); }
    .btn-teal { background: #06B6D4; color: #fff; border-radius: 999px; padding: 0.85rem 2rem; font-weight: 800; transition: all 0.2s; display: inline-block; }
    .btn-teal:hover { background: #0aa5c0; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(6,182,212,0.35); }
    input:focus, select:focus, textarea:focus { outline: 3px solid #F97316; outline-offset: 2px; }
    @keyframes paw-bounce { 0%,100% { transform: translateY(0) rotate(-5deg); } 50% { transform: translateY(-12px) rotate(5deg); } }
    .paw-bounce { animation: paw-bounce 1.8s ease-in-out infinite; display: inline-block; }
    .grad-coral { background: linear-gradient(135deg, #F97316, #FCD34D); }
    .grad-teal { background: linear-gradient(135deg, #06B6D4, #34D399); }
    .grad-yellow { background: linear-gradient(135deg, #FCD34D, #F97316); }
    html { scroll-behavior: smooth; }
    section[id] { scroll-margin-top: 5rem; }
  </style>

  <!-- NAV -->
  <nav style="background:#F97316;" class="sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl paw-bounce">🐾</span>
        <span class="font-fredoka text-xl text-white">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-5 text-sm font-bold">
        <a href="#services" class="text-white/90 hover:text-white transition-colors">Services</a>
        <a href="#pricing" class="text-white/90 hover:text-white transition-colors">Pricing</a>
        <a href="#gallery" class="text-white/90 hover:text-white transition-colors">Gallery</a>
        <a href="#team" class="text-white/90 hover:text-white transition-colors">Team</a>
        <a href="#booking" class="bg-[#FCD34D] text-[#1E293B] rounded-full px-5 py-2 font-extrabold hover:bg-yellow-300 transition-colors">Book Now 🎉</a>
      </div>
      <button id="v4-menu-btn" class="md:hidden text-white text-2xl" aria-label="Open menu">☰</button>
    </div>
    <div id="v4-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3">
      <a href="#services" class="text-white/90 font-bold text-sm">Services</a>
      <a href="#pricing" class="text-white/90 font-bold text-sm">Pricing</a>
      <a href="#gallery" class="text-white/90 font-bold text-sm">Gallery</a>
      <a href="#team" class="text-white/90 font-bold text-sm">Team</a>
      <a href="#booking" class="bg-[#FCD34D] text-[#1E293B] rounded-full px-5 py-2 font-extrabold text-center">Book Now 🎉</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center text-center px-4 overflow-hidden hero-clip" style="background:linear-gradient(135deg, #F97316 50%, #06B6D4 50%);">
    <!-- decorative circles -->
    <div class="absolute top-10 left-10 w-32 h-32 rounded-full opacity-20" style="background:#FCD34D;"></div>
    <div class="absolute bottom-20 right-10 w-48 h-48 rounded-full opacity-15" style="background:#fff;"></div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <div class="text-8xl mb-4">
        <span class="paw-bounce">🐾</span>
      </div>
      <h1 class="font-fredoka text-5xl md:text-7xl text-white leading-tight mb-4 drop-shadow-lg">
        Austin's Happiest<br/>Doggy Daycare!
      </h1>
      <p class="text-white/90 text-xl mb-3 font-bold">{business.tagline}</p>
      <p class="text-white/80 text-base mb-10 max-w-lg mx-auto">{business.description}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#booking" class="bg-white text-[#F97316] rounded-full px-8 py-4 font-extrabold text-base hover:bg-[#FFF7ED] transition-colors shadow-lg">Book a Tour 🏠</a>
        <a href="#gallery" class="border-2 border-white text-white rounded-full px-8 py-4 font-extrabold text-base hover:bg-white hover:text-[#06B6D4] transition-all">See Webcams 📹</a>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        {['📹 Live Webcams', '🌳 Giant Yards', '🎓 Puppy Kindergarten', '🎉 Theme Weekends'].map((b) => (
          <span class="bg-white/20 text-white text-sm font-bold px-4 py-2 rounded-full backdrop-blur-sm">{b}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" class="py-20 px-4 -mt-10" style="background:#FFFBF7;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#F97316] font-extrabold uppercase tracking-wider text-sm mb-2">What We Offer 🐕</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">Our Services</h2>
        <p class="text-[#475569] max-w-xl mx-auto">Everything your pup needs for the best day ever, every day.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {services.map((s, i) => {
          const accents = ['#F97316', '#06B6D4', '#FCD34D', '#34D399'];
          const bgs = ['#FFF7ED', '#ECFEFF', '#FEFCE8', '#F0FDF4'];
          return (
            <div class="rounded-3xl p-8 flex flex-col gap-3 shadow-sm hover:shadow-xl transition-all hover:-translate-y-1" style={`background:${bgs[i]}; border-top: 6px solid ${accents[i]};`}>
              <div class="text-5xl">{s.icon}</div>
              <h3 class="font-fredoka text-2xl text-[#1E293B]">{s.name}</h3>
              <p class="text-[#475569] text-sm leading-relaxed flex-grow">{s.description}</p>
              <span class="inline-block font-extrabold text-white rounded-full px-4 py-1.5 text-sm self-start" style={`background:${accents[i]};`}>{s.price}</span>
              <ul class="space-y-1 mt-1">
                {s.highlights.map((h) => (
                  <li class="text-xs text-[#475569] flex items-center gap-2 font-semibold">
                    <span style={`color:${accents[i]};`} class="font-bold">✓</span> {h}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- HEALTH & REQUIREMENTS -->
  <section class="py-16 px-4" style="background:#FFFBF7;">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10">
        <p class="text-[#F97316] font-extrabold uppercase tracking-wider text-sm mb-2">House Rules 📋</p>
        <h2 class="font-fredoka text-4xl text-[#1E293B] mb-3">Health &amp; Requirements</h2>
        <p class="text-[#475569] max-w-lg mx-auto text-sm">We need all the shots! 💉 Here's what every pup needs to join the fun.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {[
          { emoji: '💉', color: '#F97316', bg: '#FFF7ED', title: 'Vaccination Requirements', body: 'Current Rabies, Bordetella (within 6 months), and DHPP/DA2PP required. Records uploaded before Day 1.' },
          { emoji: '🤝', color: '#06B6D4', bg: '#ECFEFF', title: 'Temperament Assessment', body: 'New pups do a free 30-min meet & greet in the yard before their first booking. We want everyone to get along!' },
          { emoji: '🛡️', color: '#FCD34D', bg: '#FEFCE8', title: 'Health Guarantee', body: 'Dogs must be flea/tick free, not in heat, and free of any contagious illness on every drop-off day.' },
          { emoji: '🚨', color: '#34D399', bg: '#F0FDF4', title: 'Emergency Protocol', body: "24/7 vet partner on call. You're called immediately — before any treatment decision. We don't wait." },
        ].map((card) => (
          <div class="rounded-3xl p-6 flex gap-4 items-start" style={`background:${card.bg}; border-top: 5px solid ${card.color};`}>
            <div class="text-3xl flex-shrink-0">{card.emoji}</div>
            <div>
              <h3 class="font-fredoka text-xl text-[#1E293B] mb-1">{card.title}</h3>
              <p class="text-sm text-[#475569] leading-relaxed">{card.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS SECTION "Why Dogs Love Us" -->
  <section class="py-16 px-4" style="background:#1E293B;">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-fredoka text-4xl text-white text-center mb-12">Why Dogs Love Us 🐶</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
        <div>
          <div class="font-fredoka text-6xl text-[#F97316] mb-2">143</div>
          <p class="text-white font-bold text-lg">Happy Dogs / Week</p>
          <p class="text-white/50 text-sm mt-1">Sniffed, snuggled & loved</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl text-[#06B6D4] mb-2">4.9</div>
          <p class="text-white font-bold text-lg">⭐ Average Rating</p>
          <p class="text-white/50 text-sm mt-1">From 400+ real reviews</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl text-[#FCD34D] mb-2">24/7</div>
          <p class="text-white font-bold text-lg">Live Webcam Streams</p>
          <p class="text-white/50 text-sm mt-1">Watch your pup anytime</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl text-[#34D399] mb-2">6</div>
          <p class="text-white font-bold text-lg">🎓 Puppy Classes / Month</p>
          <p class="text-white/50 text-sm mt-1">Small groups, big progress</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-20 px-4" style="background:#FFFBF7;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#06B6D4] font-extrabold uppercase tracking-wider text-sm mb-2">Plans & Packages 🎁</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">Pick Your Plan</h2>
        <p class="text-[#475569] max-w-xl mx-auto">Every plan comes with our signature happiness guarantee.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {packages.map((pkg, i) => {
          const grads = ['grad-coral', 'grad-teal', 'grad-yellow'];
          return (
            <div class={`rounded-3xl overflow-hidden flex flex-col shadow-md hover:shadow-2xl transition-all hover:-translate-y-1 ${pkg.featured ? 'scale-105 shadow-2xl' : ''}`}>
              <div class={`${grads[i]} p-6 text-white text-center`}>
                {pkg.featured && <div class="inline-block bg-white/30 text-white text-xs font-extrabold px-3 py-1 rounded-full mb-2">🌟 Best Value</div>}
                <h3 class="font-fredoka text-2xl mb-1">{pkg.name}</h3>
                <p class="text-white/80 text-sm">{pkg.period}</p>
                <div class="font-fredoka text-5xl mt-3">{pkg.price}</div>
              </div>
              <div class="bg-white p-6 flex flex-col gap-3 flex-grow">
                <p class="text-[#475569] text-sm">{pkg.description}</p>
                <ul class="space-y-2 flex-grow">
                  {pkg.features.map((f) => (
                    <li class="text-sm text-[#475569] flex items-start gap-2 font-semibold">
                      <span class="text-[#F97316] font-bold mt-0.5">🐾</span> {f}
                    </li>
                  ))}
                </ul>
                <a href="#booking" class={`text-center rounded-full py-3 font-extrabold text-sm mt-2 transition-all ${i === 1 ? 'btn-teal' : 'btn-coral'}`}>
                  Get Started!
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="py-20 px-4" style="background:#ECFEFF;">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#06B6D4] font-extrabold uppercase tracking-wider text-sm mb-2">Sneak Peek 📸</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">The Happy Place</h2>
        <p class="text-[#475569] max-w-xl mx-auto">Every photo was taken on a regular Tuesday. This is just what it looks like here.</p>
      </div>
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {gallery.map((img, i) => {
          const shadows = ['rgba(249,115,22,0.3)', 'rgba(6,182,212,0.3)', 'rgba(252,211,77,0.4)', 'rgba(249,115,22,0.3)', 'rgba(6,182,212,0.3)', 'rgba(52,211,153,0.3)', 'rgba(249,115,22,0.3)', 'rgba(6,182,212,0.3)'];
          return (
            <div class="break-inside-avoid group relative overflow-hidden rounded-2xl" style={`box-shadow: 0 4px 20px ${shadows[i % shadows.length]};`}>
              <img src={img.url} alt={img.alt} loading="lazy" class="w-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all flex items-end p-4">
                <p class="text-white font-fredoka text-lg opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg">{img.caption}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-16 px-4" style="background:#FFFBF7;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#06B6D4] font-extrabold uppercase tracking-wider text-sm mb-2">Super Easy 🎈</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">How It Works</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-fredoka text-white grad-coral">1</div>
          <h3 class="font-fredoka text-2xl text-[#1E293B]">Fill Out the Form 📝</h3>
          <p class="text-sm text-[#475569] leading-relaxed">Quick 3-minute form tells us about your pup — energy level, breed, dietary needs, favorite toy.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-fredoka text-white grad-teal">2</div>
          <h3 class="font-fredoka text-2xl text-[#1E293B]">Meet &amp; Greet at the Yard 🏠</h3>
          <p class="text-sm text-[#475569] leading-relaxed">Come by for a free sniff session! We meet your pup, you meet the team, and everyone gets excited.</p>
        </div>
        <div class="text-center flex flex-col items-center gap-4">
          <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold font-fredoka text-white" style="background:linear-gradient(135deg,#FCD34D,#F97316);">3</div>
          <h3 class="font-fredoka text-2xl text-[#1E293B]">First Day Free! 🎉</h3>
          <p class="text-sm text-[#475569] leading-relaxed">New clients get their first day for just $10. Drop off, check the webcam, and smile all day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="py-20 px-4" style="background:#FFFBF7;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#F97316] font-extrabold uppercase tracking-wider text-sm mb-2">The Dream Team 💪</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">Your Pup's People</h2>
        <p class="text-[#475569] max-w-xl mx-auto">Passionate, certified, and powered entirely by unconditional love for dogs.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {team.map((member, i) => {
          const borders = ['#F97316', '#06B6D4', '#FCD34D'];
          return (
            <div class="rounded-3xl overflow-hidden bg-white shadow-md hover:shadow-xl transition-all hover:-translate-y-1">
              <div style={`height:5px; background:${borders[i]};`}></div>
              <div class="p-6 flex flex-col items-center text-center gap-3">
                <img src={member.photo} alt={`Photo of ${member.name}, ${member.role}`} class="w-24 h-24 rounded-full object-cover shadow-md" style={`border: 4px solid ${borders[i]};`} />
                <h3 class="font-fredoka text-xl text-[#1E293B]">{member.name}</h3>
                <p class="font-bold text-sm" style={`color:${borders[i]};`}>{member.role}</p>
                <p class="text-sm text-[#475569] leading-relaxed">{member.bio}</p>
                <div class="flex flex-wrap justify-center gap-2">
                  {member.certifications.map((cert) => (
                    <span class="text-xs font-semibold px-3 py-1 rounded-full" style={`background:${borders[i]}20; color:${borders[i]};`}>{cert}</span>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="py-20 px-4" style="background:#1E293B;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#FCD34D] font-extrabold uppercase tracking-wider text-sm mb-2">Reviews</p>
        <h2 class="font-fredoka text-5xl text-white mb-3">What the Parents Say 🗣️</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => {
          const bgs = ['#FFF7ED', '#ECFEFF', '#FEFCE8'];
          const colors = ['#F97316', '#06B6D4', '#FCD34D'];
          return (
            <div class="rounded-3xl p-6 flex flex-col gap-4" style={`background:${bgs[i]};`}>
              <div class="flex gap-1 text-xl" aria-label={`${t.stars} out of 5 stars`} style={`color:${colors[i]};`}>
                {'🐾'.repeat(t.stars)}
              </div>
              <blockquote class="text-[#1E293B] leading-relaxed italic flex-grow text-sm font-semibold">"{t.text}"</blockquote>
              <div>
                <p class="font-extrabold text-[#1E293B]">{t.name}</p>
                <p class="text-xs text-[#475569]">{t.breed} · {t.date}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4" style="background:#FFFBF7;">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#F97316] font-extrabold uppercase tracking-wider text-sm mb-2">Good Questions! 🐾</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">FAQs</h2>
      </div>
      <div class="flex flex-col gap-3" id="v4-faq">
        {[
          { q: 'How do I access the webcam?', a: 'We email you a unique stream link on your first drop-off morning. It\'s your link forever.' },
          { q: 'What\'s the dog-to-staff ratio?', a: 'Max 8 dogs per staff member during active play. Rest time is supervised but lower staffing.' },
          { q: 'My dog isn\'t spayed/neutered. Is that OK?', a: 'Intact males over 6 months need a temperament assessment. Females in heat cannot attend daycare.' },
          { q: 'What if my dog doesn\'t get along with others?', a: 'We do a free meet-and-greet before the first full day. Dogs who don\'t pass our temperament screen aren\'t admitted—this protects everyone.' },
          { q: 'Can I bring my dog\'s food?', a: 'Yes! We have labeled storage for all personal food and medications. Feeding on your schedule.' },
        ].map((item, i) => {
          const colors = ['#F97316', '#06B6D4', '#FCD34D', '#34D399', '#F97316'];
          const bgs = ['#FFF7ED', '#ECFEFF', '#FEFCE8', '#F0FDF4', '#FFF7ED'];
          return (
            <div class="rounded-3xl overflow-hidden" style={`background:${bgs[i]}; border-top: 4px solid ${colors[i]};`}>
              <button class="faq-trigger w-full text-left px-6 py-4 flex items-center justify-between gap-4 font-fredoka text-xl text-[#1E293B] hover:opacity-80 transition-opacity" data-idx={i}>
                <span>{item.q}</span>
                <span class="faq-caret text-2xl flex-shrink-0 transition-transform duration-300" style={`color:${colors[i]};`}>🐾</span>
              </button>
              <div class="faq-answer overflow-hidden" style="max-height:0; transition:max-height 0.35s ease; background:#fff;">
                <p class="px-6 py-4 text-sm text-[#475569] leading-relaxed font-semibold">{item.a}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- BOOKING FORM -->
  <section id="booking" class="py-20 px-4" style="background:#FFFBF7;">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">Book Your Pup's Spot 🎉</h2>
        <p class="text-[#475569]">Fill it out and we'll reach out within 24 hours to lock it in!</p>
      </div>
      <div id="v4-form-wrap" class="rounded-3xl bg-white shadow-xl p-8 border border-orange-100">
        <form id="v4-booking-form" class="flex flex-col gap-5" novalidate>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v4-owner-name" class="text-sm font-extrabold text-[#1E293B]">Your Name <span class="text-[#F97316]">*</span></label>
              <input id="v4-owner-name" name="ownerName" type="text" required placeholder="Your full name" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v4-pet-name" class="text-sm font-extrabold text-[#1E293B]">Dog's Name <span class="text-[#F97316]">*</span></label>
              <input id="v4-pet-name" name="petName" type="text" required placeholder="Your pup's name" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v4-email" class="text-sm font-extrabold text-[#1E293B]">Email <span class="text-[#F97316]">*</span></label>
              <input id="v4-email" name="email" type="email" required placeholder="you@email.com" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v4-phone" class="text-sm font-extrabold text-[#1E293B]">Phone <span class="text-[#F97316]">*</span></label>
              <input id="v4-phone" name="phone" type="tel" required placeholder="(512) 000-0000" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316]" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1">
              <label for="v4-breed" class="text-sm font-extrabold text-[#1E293B]">Breed</label>
              <input id="v4-breed" name="breed" type="text" placeholder="e.g. Corgi" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316]" />
            </div>
            <div class="flex flex-col gap-1">
              <label for="v4-service" class="text-sm font-extrabold text-[#1E293B]">Service <span class="text-[#F97316]">*</span></label>
              <select id="v4-service" name="service" required class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] focus:border-[#F97316]">
                <option value="">Choose a service…</option>
                {services.map((s) => <option value={s.name}>{s.name}</option>)}
              </select>
            </div>
          </div>
          <div class="flex flex-col gap-1">
            <label for="v4-date" class="text-sm font-extrabold text-[#1E293B]">Preferred Date <span class="text-[#F97316]">*</span></label>
            <input id="v4-date" name="date" type="date" required class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] focus:border-[#F97316]" />
          </div>
          <div class="flex flex-col gap-1">
            <label for="v4-notes" class="text-sm font-extrabold text-[#1E293B]">Special Needs / Anything We Should Know</label>
            <textarea id="v4-notes" name="notes" rows="4" placeholder="Energy level, friendliness with other dogs, dietary needs, favorite toy, anything you want us to know! 🐾" class="rounded-2xl border-2 border-orange-100 px-4 py-3 text-sm text-[#1E293B] placeholder:text-gray-400 focus:border-[#F97316] resize-y"></textarea>
          </div>
          <button type="submit" class="w-full rounded-full py-4 font-extrabold text-white text-base transition-all hover:-translate-y-1 hover:shadow-xl" style="background:linear-gradient(135deg, #F97316, #06B6D4);">
            Reserve Our Pup's Spot 🎉
          </button>
        </form>
        <div id="v4-booking-success" class="hidden text-center py-12">
          <div class="text-7xl mb-4">🎉</div>
          <h3 class="font-fredoka text-3xl text-[#1E293B] mb-2">Woo hoo! You're almost in!</h3>
          <p class="text-[#475569]">Thanks! We'll contact you within 24 hours to confirm your spot.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="py-20 px-4" style="background:#ECFEFF;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3">Come Find Us 📍</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        <div class="flex flex-col gap-5">
          <div class="rounded-3xl bg-white shadow-md p-6">
            <h3 class="font-fredoka text-xl text-[#1E293B] mb-4">Our Hours</h3>
            <table class="w-full text-sm text-[#475569]">
              <tbody>
                <tr class="border-b border-gray-100"><td class="py-2 font-bold">Mon – Fri</td><td class="py-2 text-right font-bold text-[#F97316]">{business.hours.weekdays}</td></tr>
                <tr class="border-b border-gray-100"><td class="py-2 font-bold">Saturday</td><td class="py-2 text-right font-bold text-[#F97316]">{business.hours.saturday}</td></tr>
                <tr><td class="py-2 font-bold">Sunday</td><td class="py-2 text-right font-bold text-[#06B6D4]">{business.hours.sunday}</td></tr>
              </tbody>
            </table>
          </div>
          <div class="rounded-3xl bg-white shadow-md p-6 flex flex-col gap-3">
            <h3 class="font-fredoka text-xl text-[#1E293B] mb-1">Let's Talk! 🐶</h3>
            <a href={`tel:${business.phone}`} class="flex items-center gap-2 text-[#475569] hover:text-[#F97316] transition-colors text-sm font-semibold">📞 {business.phone}</a>
            <a href={`mailto:${business.email}`} class="flex items-center gap-2 text-[#475569] hover:text-[#F97316] transition-colors text-sm font-semibold">✉️ {business.email}</a>
            <p class="flex items-start gap-2 text-sm text-[#475569] font-semibold">📍 {business.address}</p>
            <p class="flex items-center gap-2 text-sm text-gray-400">🚨 Emergency: {business.emergency}</p>
            <p class="text-xs text-gray-400 mt-2">{business.license}</p>
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-md" style="min-height:300px;">
          <iframe
            title={`Map to ${business.name} on South Lamar, Austin TX`}
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3445.5!2d-97.773!3d30.251!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8644b47855eb3f5d%3A0x1!2sSouth%20Lamar%20Blvd%2C%20Austin%2C%20TX!5e0!3m2!1sen!2sus!4v1620000000000!5m2!1sen!2sus"
            width="100%" height="100%" style="border:0; min-height:300px;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="background:#1E293B;" class="py-14 px-4 pb-16 md:pb-14">
    <div class="max-w-6xl mx-auto grid sm:grid-cols-3 gap-10">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🐾</span>
          <span class="font-fredoka text-xl text-white">{business.name}</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed">{business.description}</p>
        <p class="text-[#F97316] text-xs mt-4 font-bold">{business.instagram}</p>
      </div>
      <div>
        <h4 class="font-fredoka text-lg text-white mb-4">🏠 Quick Links</h4>
        <ul class="space-y-2 text-sm">
          {['#services','#pricing','#gallery','#team','#booking'].map((href, i) => (
            <li><a href={href} class="text-white/50 hover:text-[#F97316] transition-colors font-semibold">{['Services','Pricing','Gallery','Team','Book Now 🎉'][i]}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-fredoka text-lg text-white mb-4">📞 Contact Us</h4>
        <ul class="space-y-2 text-sm text-white/50 font-semibold">
          <li>{business.address}</li>
          <li><a href={`tel:${business.phone}`} class="hover:text-[#F97316] transition-colors">{business.phone}</a></li>
          <li><a href={`mailto:${business.email}`} class="hover:text-[#06B6D4] transition-colors">{business.email}</a></li>
        </ul>
        <p class="text-xs text-white/30 mt-6">© {new Date().getFullYear()} {business.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- MOBILE CTA BAR -->
  <div class="fixed bottom-0 left-0 right-0 z-50 flex md:hidden" style="height:56px;">
    <a href="tel:5127019224" class="flex-1 flex items-center justify-center gap-2 text-white font-extrabold text-sm" style="background:#1E293B;">
      <span>📞</span> Call Us!
    </a>
    <a href="#booking" class="flex-1 flex items-center justify-center gap-2 text-white font-extrabold text-sm" style="background:#F97316;">
      Book Now 🎉
    </a>
  </div>

  <script>
    const btn = document.getElementById('v4-menu-btn');
    const menu = document.getElementById('v4-mobile-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'));
      document.querySelectorAll('#v4-mobile-menu a').forEach((link) => {
        link.addEventListener('click', () => menu.classList.add('hidden'));
      });
    }
    const form = document.getElementById('v4-booking-form') as HTMLFormElement | null;
    const success = document.getElementById('v4-booking-success');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.classList.add('hidden');
        if (success) success.classList.remove('hidden');
      });
    }
    // FAQ accordion
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const parent = trigger.parentElement;
        if (!parent) return;
        const answer = parent.querySelector('.faq-answer') as HTMLElement | null;
        const isOpen = trigger.classList.contains('faq-open');
        document.querySelectorAll('.faq-trigger').forEach((t) => {
          t.classList.remove('faq-open');
          const p = t.parentElement;
          if (p) {
            const a = p.querySelector('.faq-answer') as HTMLElement | null;
            if (a) a.style.maxHeight = '0';
          }
        });
        if (!isOpen && answer) {
          trigger.classList.add('faq-open');
          answer.style.maxHeight = '500px';
        }
      });
    });
  </script>
</BaseLayout>
