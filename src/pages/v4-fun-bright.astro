---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v4/business';
import { services, packages } from '../data/v4/services';
import { gallery } from '../data/v4/gallery';

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "telephone": business.phone,
  "email": business.email,
  "address": { "@type": "PostalAddress", "streetAddress": business.address },
  "url": "https://pets.dcrader.dev/v4-fun-bright",
  "priceRange": "$",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "412" },
  "openingHours": ["Mo-Fr 06:30-19:30", "Sa 07:00-18:00", "Su 08:00-17:00"],
});
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1200&h=630&fit=crop&q=80"
  schemaJson={schemaJson}
>

  <!-- ANNOUNCEMENT BANNER -->
  <div id="v4-banner" style="background:#F97316;" class="w-full text-white text-sm text-center py-2 px-4 flex items-center justify-center gap-3 relative font-bold">
    <span>🎉 New pups! First daycare day just $10 — Sniff &amp; Snuggle Intro Special · Book today!</span>
    <button onclick="document.getElementById('v4-banner').remove()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-lg leading-none font-bold" aria-label="Close banner">×</button>
  </div>

  <style>
    body { font-family: 'Nunito', sans-serif; background: #FFFBF7; color: #475569; }
    .font-fredoka { font-family: 'Fredoka One', cursive; }

    /* ── ANIMATIONS ── */
    @keyframes wiggle {
      0%, 100% { transform: rotate(-3deg); }
      50% { transform: rotate(3deg); }
    }
    @keyframes bounce-in {
      0% { transform: scale(0.8); opacity: 0; }
      60% { transform: scale(1.05); }
      100% { transform: scale(1); opacity: 1; }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
    }
    @keyframes paw-bounce {
      0%, 100% { transform: translateY(0) rotate(-5deg); }
      50% { transform: translateY(-12px) rotate(5deg); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    @keyframes countUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .wiggle-btn:hover { animation: wiggle 0.5s ease-in-out; }
    .float-1 { animation: float 3s ease-in-out infinite; }
    .float-2 { animation: float 3.5s ease-in-out infinite 0.5s; }
    .float-3 { animation: float 4s ease-in-out infinite 1s; }
    .paw-bounce { animation: paw-bounce 1.8s ease-in-out infinite; display: inline-block; }

    @media (prefers-reduced-motion: reduce) {
      .paw-bounce, .float-1, .float-2, .float-3, .wiggle-btn:hover { animation: none; }
    }

    /* ── NAV WAVY ── */
    .nav-wavy-wrap { background: #F97316; margin-top: -1px; line-height: 0; }

    /* ── BUTTONS ── */
    .btn-coral { background: #F97316; color: #fff; border-radius: 999px; padding: 0.85rem 2rem; font-weight: 800; transition: all 0.2s; display: inline-block; }
    .btn-coral:hover { background: #ea6a0a; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(249,115,22,0.35); }
    .btn-teal { background: #06B6D4; color: #fff; border-radius: 999px; padding: 0.85rem 2rem; font-weight: 800; transition: all 0.2s; display: inline-block; }
    .btn-teal:hover { background: #0aa5c0; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(6,182,212,0.35); }
    .btn-yellow { background: #FCD34D; color: #1E293B; border-radius: 999px; padding: 0.85rem 2rem; font-weight: 800; transition: all 0.2s; display: inline-block; }
    .btn-yellow:hover { background: #f8c800; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(252,211,77,0.45); }

    /* ── GRADIENTS ── */
    .grad-coral { background: linear-gradient(135deg, #F97316, #FCD34D); }
    .grad-teal { background: linear-gradient(135deg, #06B6D4, #34D399); }
    .grad-yellow { background: linear-gradient(135deg, #FCD34D, #F97316); }

    /* ── HERO ── */
    .hero-diagonal { background: linear-gradient(135deg, #F97316 50%, #06B6D4 50%); }

    /* ── DECORATIVE DOTS (webcam section) ── */
    .dot-pattern {
      background-color: #1E293B;
      background-image: radial-gradient(circle, rgba(249,115,22,0.18) 1px, transparent 1px),
                        radial-gradient(circle, rgba(6,182,212,0.12) 1px, transparent 1px);
      background-size: 28px 28px, 56px 56px;
      background-position: 0 0, 14px 14px;
    }

    /* ── SPEECH BUBBLE TESTIMONIALS ── */
    .speech-bubble { position: relative; border-radius: 1.5rem; }
    .speech-bubble::before {
      content: '';
      position: absolute;
      left: -14px;
      top: 24px;
      border-width: 10px 14px 10px 0;
      border-style: solid;
      border-color: transparent white transparent transparent;
    }

    /* ── FAQ ── */
    .faq-answer { overflow: hidden; max-height: 0; transition: max-height 0.35s ease; }

    /* ── SERVICE CARDS ── */
    .service-card { transition: transform 0.2s, box-shadow 0.2s; }
    .service-card:hover { transform: scale(1.02); box-shadow: 0 16px 40px rgba(0,0,0,0.12); }

    /* ── GALLERY STICKER ── */
    .gallery-sticker { opacity: 0; transform: scale(0.5) rotate(-15deg); transition: all 0.3s; }
    .gallery-item:hover .gallery-sticker { opacity: 1; transform: scale(1) rotate(-5deg); }

    /* ── FORM ── */
    input:focus, select:focus, textarea:focus { outline: 3px solid #F97316; outline-offset: 2px; }

    /* ── HOW IT WORKS ARROW ── */
    .step-arrow { display: none; }
    @media (min-width: 640px) {
      .step-arrow { display: flex; align-items: center; color: #F97316; font-size: 2rem; font-weight: 900; flex-shrink: 0; margin-top: -1.5rem; }
    }

    html { scroll-behavior: smooth; }
    section[id] { scroll-margin-top: 5rem; }
  </style>

  <!-- ═══════════════════════════════════════════
       NAV — WAVY BOTTOM BORDER
  ═══════════════════════════════════════════ -->
  <nav style="background:#F97316;" class="sticky top-0 z-50 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2">
        <span class="text-2xl paw-bounce">🐾</span>
        <span class="font-fredoka text-xl text-white" style="font-family:'Fredoka One',cursive;">{business.name}</span>
      </a>
      <div class="hidden md:flex items-center gap-5 text-sm font-bold" style="font-family:'Nunito',sans-serif;">
        <a href="#services" class="text-white/90 hover:text-white transition-colors">Services</a>
        <a href="#webcams" class="text-white/90 hover:text-white transition-colors">Webcams</a>
        <a href="#pricing" class="text-white/90 hover:text-white transition-colors">Pricing</a>
        <a href="#gallery" class="text-white/90 hover:text-white transition-colors">Gallery</a>
        <a href="#team" class="text-white/90 hover:text-white transition-colors">Team</a>
        <a href="#booking" class="wiggle-btn bg-[#FCD34D] text-[#1E293B] rounded-full px-5 py-2 font-extrabold hover:bg-yellow-300 transition-colors">Book Now 🎉</a>
      </div>
      <button id="v4-menu-btn" class="md:hidden text-white text-2xl" aria-label="Open menu">☰</button>
    </div>
    <!-- Mobile menu -->
    <div id="v4-mobile-menu" class="hidden md:hidden px-4 pb-4 flex flex-col gap-3">
      <a href="#services" class="text-white/90 font-bold text-sm">Services</a>
      <a href="#webcams" class="text-white/90 font-bold text-sm">Webcams 📹</a>
      <a href="#pricing" class="text-white/90 font-bold text-sm">Pricing</a>
      <a href="#gallery" class="text-white/90 font-bold text-sm">Gallery</a>
      <a href="#team" class="text-white/90 font-bold text-sm">Team</a>
      <a href="#booking" class="bg-[#FCD34D] text-[#1E293B] rounded-full px-5 py-2 font-extrabold text-center">Book Now 🎉</a>
    </div>
  </nav>
  <!-- WAVY BOTTOM of nav -->
  <div class="nav-wavy-wrap sticky top-[56px] z-40">
    <svg viewBox="0 0 1440 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;height:24px;">
      <path d="M0,12 C120,24 240,0 360,12 C480,24 600,0 720,12 C840,24 960,0 1080,12 C1200,24 1320,0 1440,12 L1440,0 L0,0 Z" fill="#F97316"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       HERO — DIAGONAL SPLIT + LIVE CAM WIDGET
  ═══════════════════════════════════════════ -->
  <section id="hero" class="hero-diagonal relative min-h-screen flex items-center justify-center text-center px-4 overflow-hidden" style="padding-top:3rem; padding-bottom:4rem;">
    <!-- Decorative circles -->
    <div class="absolute top-10 left-10 w-40 h-40 rounded-full opacity-20" style="background:#FCD34D;"></div>
    <div class="absolute bottom-16 right-10 w-56 h-56 rounded-full opacity-10" style="background:#fff;"></div>
    <div class="absolute top-1/3 right-1/4 w-20 h-20 rounded-full opacity-15" style="background:#1E293B;"></div>
    <div class="absolute bottom-1/4 left-1/4 w-12 h-12 rounded-full opacity-20" style="background:#06B6D4;"></div>

    <!-- Floating SVG decorations -->
    <!-- Bone - top left -->
    <div class="float-1 absolute top-16 left-8 md:left-24 opacity-70 hidden sm:block" aria-hidden="true">
      <svg width="60" height="28" viewBox="0 0 60 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="9" cy="9" r="9" fill="white" opacity="0.9"/>
        <circle cx="9" cy="19" r="9" fill="white" opacity="0.9"/>
        <circle cx="51" cy="9" r="9" fill="white" opacity="0.9"/>
        <circle cx="51" cy="19" r="9" fill="white" opacity="0.9"/>
        <rect x="8" y="7" width="44" height="14" rx="4" fill="white" opacity="0.9"/>
      </svg>
    </div>

    <!-- Paw print - top right -->
    <div class="float-2 absolute top-20 right-8 md:right-24 opacity-70 hidden sm:block" aria-hidden="true">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="24" cy="30" rx="11" ry="10" fill="white" opacity="0.9"/>
        <ellipse cx="10" cy="20" rx="5" ry="6" fill="white" opacity="0.9"/>
        <ellipse cx="20" cy="14" rx="5" ry="6" fill="white" opacity="0.9"/>
        <ellipse cx="30" cy="14" rx="5" ry="6" fill="white" opacity="0.9"/>
        <ellipse cx="40" cy="20" rx="5" ry="6" fill="white" opacity="0.9"/>
      </svg>
    </div>

    <!-- Ball - bottom right -->
    <div class="float-3 absolute bottom-28 right-12 md:right-32 opacity-60 hidden sm:block" aria-hidden="true">
      <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="22" cy="22" r="22" fill="#FCD34D" opacity="0.9"/>
        <path d="M4 22 Q22 8 40 22" stroke="white" stroke-width="3" fill="none" opacity="0.6"/>
        <path d="M4 22 Q22 36 40 22" stroke="white" stroke-width="3" fill="none" opacity="0.6"/>
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-2xl mx-auto">
      <div class="text-8xl mb-4">
        <span class="paw-bounce">🐾</span>
      </div>
      <h1 class="font-fredoka text-5xl md:text-7xl text-white leading-tight mb-4 drop-shadow-lg" style="font-family:'Fredoka One',cursive;">
        Austin's Happiest<br/>Doggy Daycare!
      </h1>
      <p class="text-white/90 text-xl mb-6 font-bold" style="font-family:'Nunito',sans-serif;">{business.tagline}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#booking" class="wiggle-btn bg-white text-[#F97316] rounded-full px-8 py-4 font-extrabold text-base hover:bg-[#FFF7ED] transition-colors shadow-lg">Book a Tour 🏠</a>
        <a href="#webcams" class="border-2 border-white text-white rounded-full px-8 py-4 font-extrabold text-base hover:bg-white hover:text-[#06B6D4] transition-all">See Webcams 📹</a>
      </div>

      <!-- LIVE CAM WIDGET -->
      <div style="background:rgba(0,0,0,0.75); border-radius:16px; padding:12px; max-width:300px; margin:2rem auto 0; text-align:left; border:2px solid rgba(255,255,255,0.2);">
        <!-- Live indicator row -->
        <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
          <div style="width:10px; height:10px; border-radius:50%; background:#22C55E; animation:pulse 1.5s infinite;"></div>
          <span style="color:#22C55E; font-weight:800; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em;">LIVE</span>
          <span style="color:rgba(255,255,255,0.6); font-size:0.7rem; margin-left:auto;">Cam 2 — Yard B</span>
        </div>
        <!-- Camera feed -->
        <div style="border-radius:8px; overflow:hidden; aspect-ratio:16/9; position:relative;">
          <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=400&h=225&fit=crop&q=80" style="width:100%; height:100%; object-fit:cover; filter:contrast(0.9) brightness(1.05);" alt="Live daycare cam" loading="eager" />
          <div style="position:absolute; top:6px; right:6px; background:rgba(0,0,0,0.5); color:white; font-size:0.6rem; padding:2px 6px; border-radius:4px; font-weight:700;">14 DOGS PLAYING</div>
          <div style="position:absolute; bottom:6px; left:6px; color:rgba(255,255,255,0.7); font-size:0.6rem;">10:32 AM · 05/16/26</div>
        </div>
        <p style="color:rgba(255,255,255,0.7); font-size:0.7rem; margin-top:8px; text-align:center;">Members get live access 24/7</p>
      </div>

      <!-- Feature badges -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {['📹 Live Webcams', '🌳 Giant Yards', '🎓 Puppy Kindergarten', '🎉 Theme Weekends'].map((b) => (
          <span class="bg-white/20 text-white text-sm font-bold px-4 py-2 rounded-full backdrop-blur-sm border border-white/20" style="font-family:'Nunito',sans-serif;">{b}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES — BUBBLE/BLOB CARDS (2×2 grid)
  ═══════════════════════════════════════════ -->
  <section id="services" class="py-20 px-4" style="background:#FFFBF7;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#F97316] font-extrabold uppercase tracking-wider text-sm mb-2" style="font-family:'Nunito',sans-serif;">What We Offer 🐕</p>
        <h2 class="font-fredoka text-5xl text-[#1E293B] mb-3" style="font-family:'Fredoka One',cursive;">Our Services</h2>
        <p class="text-[#475569] max-w-xl mx-auto" style="font-family:'Nunito',sans-serif;">Everything your pup needs for the best day ever, every single day.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-8">
        {services.map((s, i) => {
          const accents = ['#F97316', '#06B6D4', '#FCD34D', '#F97316'];
          const bgs = ['#FFF7ED', '#ECFEFF', '#FEFCE8', '#F0FDF4'];
          const borderWidths = ['8px', '8px', '8px', '8px'];
          return (
            <div class="service-card rounded-3xl p-8 flex flex-col gap-4 shadow-md" style={`background:${bgs[i]}; border-top:${borderWidths[i]} solid ${accents[i]};`}>
              <div class="text-6xl">{s.icon}</div>
              <h3 class="font-fredoka text-3xl text-[#1E293B]" style="font-family:'Fredoka One',cursive;">{s.name}</h3>
              <p class="text-[#475569] text-sm leading-relaxed flex-grow" style="font-family:'Nunito',sans-serif;">{s.description}</p>
              <span class="inline-block font-extrabold text-white rounded-full px-5 py-2 text-sm self-start shadow-sm" style={`background:${accents[i]};`}>{s.price}</span>
              <ul class="space-y-1.5 mt-1">
                {s.highlights.map((h) => (
                  <li class="text-sm text-[#475569] flex items-center gap-2 font-semibold" style="font-family:'Nunito',sans-serif;">
                    <span style={`color:${accents[i]};`} class="font-bold text-lg leading-none">✓</span> {h}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       STATS STRIP — CORAL BACKGROUND
  ═══════════════════════════════════════════ -->
  <section class="py-16 px-4" style="background:#F97316;">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
        <div>
          <div class="font-fredoka text-6xl md:text-7xl text-white mb-2 stat-num" data-target="412" style="font-family:'Fredoka One',cursive;">412</div>
          <p class="text-white font-extrabold text-base" style="font-family:'Nunito',sans-serif;">Reviews</p>
          <p class="text-white/70 text-xs mt-1" style="font-family:'Nunito',sans-serif;">On Google &amp; Yelp</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl md:text-7xl text-white mb-2" style="font-family:'Fredoka One',cursive;">4.9<span class="text-4xl">★</span></div>
          <p class="text-white font-extrabold text-base" style="font-family:'Nunito',sans-serif;">Average Rating</p>
          <p class="text-white/70 text-xs mt-1" style="font-family:'Nunito',sans-serif;">From real parents</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl md:text-7xl text-white mb-2" style="font-family:'Fredoka One',cursive;">3</div>
          <p class="text-white font-extrabold text-base" style="font-family:'Nunito',sans-serif;">Yards of Play Space</p>
          <p class="text-white/70 text-xs mt-1" style="font-family:'Nunito',sans-serif;">Indoor + outdoor</p>
        </div>
        <div>
          <div class="font-fredoka text-6xl md:text-7xl text-[#1E293B] mb-2" style="font-family:'Fredoka One',cursive;" data-target="14">14</div>
          <p class="text-white font-extrabold text-base" style="font-family:'Nunito',sans-serif;">Dogs Per Day Avg</p>
          <p class="text-white/70 text-xs mt-1" style="font-family:'Nunito',sans-serif;">Small groups, big love</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LIVE CAM PROMO SECTION — DEDICATED
  ═══════════════════════════════════════════ -->
  <section id="webcams" class="dot-pattern py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div>
          <p class="text-[#06B6D4] font-extrabold uppercase tracking-wider text-xs mb-3" style="font-family:'Nunito',sans-serif;">Live from daycare 📹</p>
          <h2 class="font-fredoka text-4xl md:text-5xl text-[#F97316] mb-4 leading-tight" style="font-family:'Fredoka One',cursive;">Watch Your Pup<br/>Play <span style="color:#FCD34D;">LIVE</span></h2>
          <p class="text-white/75 text-lg leading-relaxed mb-6" style="font-family:'Nunito',sans-serif;">Can't stop thinking about your pup? Our webcam portal gives you live HD access to all three play yards — all day, every day. No refresh needed. No anxiety necessary.</p>
          <div class="flex flex-wrap gap-3 mb-8">
            {['📺 HD Video', '📱 Mobile-friendly', '🕐 Available 24/7', '🔓 No login required'].map((f) => (
              <span class="bg-white/10 border border-white/20 text-white text-sm font-semibold px-4 py-2 rounded-full" style="font-family:'Nunito',sans-serif;">{f}</span>
            ))}
          </div>
          <a href="#booking" class="wiggle-btn btn-coral inline-block" style="font-family:'Nunito',sans-serif;">Get Access 📹</a>
        </div>

        <!-- Right: 3 fake webcam thumbnails -->
        <div class="grid grid-cols-2 gap-3">
          <!-- Large cam -->
          <div class="col-span-2 rounded-2xl overflow-hidden relative group" style="aspect-ratio:16/9; background:#0F172A;">
            <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=600&h=338&fit=crop&q=80" alt="Yard A live webcam" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute top-2 left-3 flex items-center gap-2">
              <div style="width:8px;height:8px;border-radius:50%;background:#22C55E;animation:pulse 1.5s infinite;"></div>
              <span style="color:#22C55E;font-weight:800;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;">LIVE</span>
            </div>
            <div class="absolute bottom-2 left-3 text-white/70 text-xs font-mono">YARD A · Main Play Floor</div>
            <div class="absolute top-2 right-3 bg-black/50 text-white text-xs px-2 py-0.5 rounded font-bold">12 DOGS</div>
          </div>
          <!-- Small cam 1 -->
          <div class="rounded-xl overflow-hidden relative group" style="aspect-ratio:4/3; background:#0F172A;">
            <img src="https://images.unsplash.com/photo-1530143584537-c7cc7da4b9b4?w=400&h=300&fit=crop&q=80" alt="Yard B live webcam" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute top-2 left-2 flex items-center gap-1">
              <div style="width:6px;height:6px;border-radius:50%;background:#22C55E;animation:pulse 1.5s infinite 0.3s;"></div>
              <span style="color:#22C55E;font-size:0.55rem;font-weight:800;text-transform:uppercase;">LIVE</span>
            </div>
            <div class="absolute bottom-2 left-2 text-white/70 text-xs font-mono">YARD B</div>
          </div>
          <!-- Small cam 2 -->
          <div class="rounded-xl overflow-hidden relative group" style="aspect-ratio:4/3; background:#0F172A;">
