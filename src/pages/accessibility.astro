---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Accessibility Statement" description="Accessibility statement and WCAG 2.1 AA commitment.">
  <main class="max-w-3xl mx-auto px-6 py-16 prose">
    <h1>Accessibility Statement</h1>
    <p>This site is committed to ensuring digital accessibility for people of all abilities. We strive to conform to WCAG 2.1 Level AA standards. If you experience difficulty accessing any part of this site, please contact us.</p>
    <p>Last updated: 2026-05-17</p>
  </main>
</BaseLayout>
