              <option value="executive" style="background:#0F172A;">Executive Room — From $145/night</option>
              <option value="spa" style="background:#0F172A;">Signature Spa Day — From $195</option>
              <option value="training" style="background:#0F172A;">Private Training — From $125/hr</option>
              <option value="package-weekender" style="background:#0F172A;">Package: Weekender — $385</option>
              <option value="package-grand" style="background:#0F172A;">Package: Grand Estate Stay — $1,650</option>
              <option value="package-day" style="background:#0F172A;">Package: Day Retreat — $245</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="v5-requirements" class="font-montserrat tracking-widest uppercase text-white/70 font-semibold" style="font-size:0.62rem; letter-spacing:0.16em;">Special Requirements</label>
