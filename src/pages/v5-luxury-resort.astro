---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, team, testimonials } from '../data/v5/business';
import { services, packages } from '../data/v5/services';
import { gallery } from '../data/v5/gallery';
import { img } from '../data/images';
const heroImg = img('1518717758536');

const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "description": business.description,
  "telephone": business.phone,
  "email": business.email,
  "address": { "@type": "PostalAddress", "streetAddress": business.address },
  "url": "https://dcrader-template-pets.vercel.app/v5-luxury-resort",
  "priceRange": "$$$$",
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "194" },
  "openingHours": ["Mo-Fr 07:00-21:00", "Sa 08:00-20:00", "Su 09:00-19:00"],
});

const serviceImages = [
  img('1561037404'),
  img('1587300003388'),
  img('1510771463146'),
  img('1560743641'),
];
---
<BaseLayout
  title={`${business.name} — ${business.tagline}`}
  description={business.description}
  ogImage="/images/photo-1518717758536-85ae29035b6d-1600.webp"
  heroImage={heroImg.src}
  schemaJson={schemaJson}
>

  <style>
    /* ── Fonts & Base ── */
    body { font-family: 'Montserrat', sans-serif; background: #F8F5F0; color: #334155; }
    .font-cormorant { font-family: 'Cormorant Garamond', Georgia, serif; }
    .font-montserrat { font-family: 'Montserrat', sans-serif; }

    /* ── Color helpers ── */
    .gold { color: #D4AF37; }
    .bg-navy { background: #0F172A; }

    /* ── Buttons ── */
    .btn-gold-outline {
      border: 1px solid #D4AF37;
      color: #D4AF37;
      background: transparent;
      border-radius: 1px;
      padding: 0.85rem 2.5rem;
      font-family: 'Montserrat', sans-serif;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 0.72rem;
      transition: all 0.3s;
      display: inline-block;
    }
    .btn-gold-outline:hover { background: #D4AF37; color: #0F172A; }
    .btn-gold-solid {
      background: #D4AF37;
      color: #0F172A;
      border: 1px solid #D4AF37;
      border-radius: 1px;
      padding: 0.85rem 2.5rem;
      font-family: 'Montserrat', sans-serif;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-size: 0.72rem;
      transition: all 0.3s;
      display: inline-block;
    }
    .btn-gold-solid:hover { background: #B8860B; border-color: #B8860B; }

    /* ── Gold rule ── */
    .gold-rule { height: 1px; background: linear-gradient(90deg, transparent, #D4AF37, transparent); margin: 0 auto; }
    .gold-rule-left { height: 1px; background: linear-gradient(90deg, #D4AF37, transparent); margin: 0; }

    /* ── Amenity ticker ── */
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .ticker-inner {
      display: inline-flex;
      animation: ticker 30s linear infinite;
      white-space: nowrap;
    }
    .ticker-wrap { overflow: hidden; }

    /* ── Gallery hover caption ── */
    .gallery-item { position: relative; overflow: hidden; }
    .gallery-caption {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(15,23,42,0.85), transparent);
      padding: 1.5rem 1rem 1rem;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .gallery-item:hover .gallery-caption { opacity: 1; }

    /* ── Team portrait strip ── */
    .team-strip { display: flex; overflow-x: auto; gap: 0; padding-bottom: 0; }
    .team-strip::-webkit-scrollbar { height: 0; }
    .team-member { flex: none; width: 280px; position: relative; }
    .team-overlay {
      position: absolute; inset: 0;
      background: rgba(15,23,42,0);
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 1.5rem;
      opacity: 0;
      transition: all 0.35s;
    }
    .team-member:hover .team-overlay { background: rgba(15,23,42,0.75); opacity: 1; }

    /* ── FAQ ── */
    .faq-answer { overflow: hidden; max-height: 0; transition: max-height 0.35s ease; }

    /* ── Form focus ── */
    input:focus, select:focus, textarea:focus { outline: 1px solid #D4AF37; outline-offset: 2px; }

    /* ── Scroll behavior ── */
    html { scroll-behavior: smooth; }
    section[id] { scroll-margin-top: 5rem; }

    /* ── Nav border ── */
    .nav-border { border-bottom: 1px solid rgba(212,175,55,0.2); }

    /* ── Press names ── */
    .press-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      color: rgba(15,23,42,0.22);
      font-size: 1.35rem;
      letter-spacing: 0.03em;
      transition: color 0.3s;
      user-select: none;
    }
    .press-name:hover { color: rgba(15,23,42,0.5); }

    /* ── Mobile: fix fixed nav attachment ── */
    @media (max-width: 768px) {
      .hero-fixed { background-attachment: scroll !important; }
    }
  </style>

  <!-- ══════════════════════════════════════════
       1. ANNOUNCEMENT STRIP
  ══════════════════════════════════════════ -->
  <div id="v5-banner" style="background:#0F172A; border-bottom:1px solid #D4AF37; position:relative;" class="w-full py-2 px-4 flex items-center justify-center">
    <span class="font-montserrat tracking-widest text-center" style="color:#D4AF37; font-size:0.7rem; letter-spacing:0.16em;">
      ✦ Summer availability limited — reserve your suite for July &amp; August &nbsp;·&nbsp; Reservations: {business.phone}
    </span>
    <button
      onclick="document.getElementById('v5-banner').remove()"
      aria-label="Dismiss"
      style="position:absolute; right:1rem; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3); font-size:1.1rem; font-weight:300; line-height:1; background:none; border:none; cursor:pointer; padding:0.25rem;"
    >×</button>
  </div>

  <!-- ══════════════════════════════════════════
       2. NAV — CENTERED LOGO
  ══════════════════════════════════════════ -->
  <nav style="background:#0F172A; border-bottom:1px solid rgba(212,175,55,0.2);" class="sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-4 relative flex items-center">

      <!-- Left links -->
      <div class="hidden md:flex items-center gap-8 flex-1">
        <a href="#services" class="font-montserrat text-white/60 hover:text-[#D4AF37] transition-colors" style="font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase;">Services</a>
        <a href="#gallery" class="font-montserrat text-white/60 hover:text-[#D4AF37] transition-colors" style="font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase;">Gallery</a>
        <a href="#pricing" class="font-montserrat text-white/60 hover:text-[#D4AF37] transition-colors" style="font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase;">Packages</a>
      </div>

      <!-- Center logo (absolute center) -->
      <div class="absolute left-1/2 -translate-x-1/2 flex flex-col items-center pointer-events-none select-none">
        <span class="font-cormorant font-semibold tracking-widest" style="color:#D4AF37; font-size:1.15rem; letter-spacing:0.22em;">THE HOLLOW</span>
        <span class="font-montserrat tracking-widest uppercase" style="color:rgba(255,255,255,0.28); font-size:0.6rem; letter-spacing:0.18em;">Pet Hotel &amp; Spa</span>
      </div>

      <!-- Right links -->
      <div class="hidden md:flex items-center gap-8 flex-1 justify-end">
        <a href="#team" class="font-montserrat text-white/60 hover:text-[#D4AF37] transition-colors" style="font-size:0.72rem; letter-spacing:0.14em; text-transform:uppercase;">Team</a>
        <a href="#booking" class="btn-gold-outline" style="padding:0.6rem 1.5rem;">Reserve</a>
      </div>

      <!-- Mobile hamburger -->
      <button id="v5-menu-btn" class="md:hidden text-[#D4AF37] text-2xl ml-auto" aria-label="Open menu">☰</button>
    </div>

    <!-- Mobile menu -->
    <div id="v5-mobile-menu" class="hidden md:hidden px-6 pb-4 flex flex-col gap-3 border-t border-white/10">
      <a href="#services" class="font-montserrat text-white/60 text-xs uppercase tracking-widest py-2">Services</a>
      <a href="#gallery" class="font-montserrat text-white/60 text-xs uppercase tracking-widest py-2">Gallery</a>
      <a href="#pricing" class="font-montserrat text-white/60 text-xs uppercase tracking-widest py-2">Packages</a>
      <a href="#team" class="font-montserrat text-white/60 text-xs uppercase tracking-widest py-2">Team</a>
      <a href="#booking" class="btn-gold-outline text-center text-xs">Reserve</a>
    </div>
  </nav>

  <!-- ══════════════════════════════════════════
       3. HERO — FULL-SCREEN EDITORIAL
  ══════════════════════════════════════════ -->
  <section id="hero" class="relative flex items-center justify-center text-center overflow-hidden" style="min-height:100vh;">
    <!-- Background image -->
    <div class="hero-fixed" style="position:absolute;inset:0;background-image:url('/images/photo-1518717758536-85ae29035b6d-1600.webp');background-size:cover;background-position:center;background-attachment:fixed;"></div>
    <!-- Dark overlay -->
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom, rgba(15,23,42,0.58) 0%, rgba(15,23,42,0.78) 100%);"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 py-24">
      <!-- Top label -->
      <p class="font-montserrat tracking-widest uppercase mb-8" style="color:rgba(255,255,255,0.38); font-size:0.68rem; letter-spacing:0.2em;">
        Est. {business.founded} &nbsp;·&nbsp; Beverly Hills &nbsp;·&nbsp; By Appointment
      </p>
      <!-- Gold rule -->
      <div class="gold-rule mb-8" style="max-width:180px;"></div>
      <!-- H1 -->
      <h1 class="font-cormorant font-light italic text-white leading-none mb-6" style="font-size:clamp(3.5rem, 10vw, 7rem); line-height:0.95;">
        Where Extraordinary<br/>Pets Receive<br/>Extraordinary Care
      </h1>
      <!-- Gold rule -->
      <div class="gold-rule mt-8 mb-8" style="max-width:180px;"></div>
      <!-- Subtitle -->
      <p class="font-montserrat tracking-widest uppercase mb-12" style="color:rgba(255,255,255,0.38); font-size:0.68rem; letter-spacing:0.2em;">
        {business.phone} &nbsp;·&nbsp; Reservations Required
      </p>
      <!-- CTA -->
      <a href="#booking" class="btn-gold-outline" style="padding:1.2rem 4rem; font-size:0.72rem;">Reserve Your Suite</a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       4. AMENITY TICKER STRIP
  ══════════════════════════════════════════ -->
  <div class="ticker-wrap py-4" style="background:#0F172A; border-top:1px solid rgba(212,175,55,0.35); border-bottom:1px solid rgba(212,175,55,0.35);">
    <div class="ticker-inner">
      {[1,2].map(() => (
        <span class="font-montserrat tracking-widest uppercase" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.2em; padding:0 2.5rem;">
          ✦ Presidential Suites &nbsp;·&nbsp; Organic Cuisine &nbsp;·&nbsp; Spa &amp; Wellness &nbsp;·&nbsp; 24/7 Veterinary Care &nbsp;·&nbsp; Private Training &nbsp;·&nbsp; Chauffeur Transfers &nbsp;·&nbsp; In-Suite HD Cameras &nbsp;·&nbsp; Certified Canine Nutritionist &nbsp;·&nbsp; Beverly Hills &nbsp;·&nbsp; By Appointment Only &nbsp;
        </span>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       PRESS STRIP
  ══════════════════════════════════════════ -->
  <section class="py-12 px-4 bg-white border-b border-[#E2E8F0]">
    <div class="max-w-6xl mx-auto">
      <p class="text-center font-montserrat tracking-widest uppercase text-[#94A3B8] mb-8" style="font-size:0.65rem; letter-spacing:0.2em;">As Featured In</p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16">
        {['Pet Business Magazine', 'Modern Dog', 'Robb Report', 'Beverly Hills Courier', 'Dog Fancy'].map((pub) => (
          <span class="press-name">{pub}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       5. SERVICES — EDITORIAL LOOKBOOK
  ══════════════════════════════════════════ -->
  <section id="services" style="background:#F8F5F0;">
    <!-- Section header -->
    <div class="text-center pt-20 pb-0 px-4">
      <p class="font-montserrat tracking-widest uppercase mb-3" style="color:#D4AF37; font-size:0.68rem; letter-spacing:0.2em;">Our Offerings</p>
      <h2 class="font-cormorant font-light italic text-[#0F172A]" style="font-size:clamp(2.5rem,5vw,3.5rem);">The Services</h2>
      <div class="gold-rule mt-5 mb-0" style="max-width:120px;"></div>
    </div>

    {services.map((s, i) => (
      <div class={`grid md:grid-cols-2 ${i % 2 !== 0 ? 'md:[grid-template-areas:"text_image"]' : ''}`} style="min-height:520px; border-bottom:1px solid #E2E8F0;">
        <!-- Image side -->
        <div
          class="relative overflow-hidden"
          style={`${i % 2 !== 0 ? 'order:2;' : 'order:1;'} min-height:360px;`}
        >
          <Picture
            src={serviceImages[i]}
            alt={s.name}
            widths={[600, 900, 1200]}
            sizes="(max-width: 768px) 100vw, 50vw"
            formats={['avif','webp']}
            fallbackFormat="webp"
            quality={75}
            loading="lazy"
            decoding="async"
            style="width:100%; height:100%; object-fit:cover; min-height:360px; display:block;"
          />
          <!-- Gold corner ornament -->
          <div style="position:absolute; top:20px; left:20px; color:#D4AF37; font-size:1.4rem; opacity:0.45; line-height:1;">✦</div>
        </div>

        <!-- Text side -->
        <div
          class="flex flex-col justify-center px-10 md:px-14 py-16 bg-[#F8F5F0]"
          style={i % 2 !== 0 ? 'order:1;' : 'order:2;'}
        >
          <p class="font-montserrat tracking-widest uppercase mb-4" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.2em;">{s.icon} &nbsp;Service</p>
          <div class="gold-rule-left mb-6" style="width:48px; opacity:0.5;"></div>
          <h3 class="font-cormorant font-light italic text-[#0F172A] mb-4" style="font-size:2.25rem;">{s.name}</h3>
          <p class="font-montserrat text-sm text-[#334155] leading-relaxed mb-7" style="font-weight:300;">{s.description}</p>
          <ul class="space-y-2 mb-8">
            {s.highlights.map((h) => (
              <li class="flex items-center gap-3 font-montserrat text-sm text-[#334155]" style="font-weight:300;">
                <span style="color:#D4AF37; font-weight:400;">—</span> {h}
              </li>
            ))}
          </ul>
          <div class="flex items-center gap-6">
            <p class="font-montserrat tracking-widest uppercase" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.18em;">{s.price}</p>
            <a href="#booking" class="font-montserrat tracking-widest uppercase text-[#0F172A]/50 hover:text-[#D4AF37] transition-colors" style="font-size:0.65rem; letter-spacing:0.18em;">Request Information →</a>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- ══════════════════════════════════════════
       HEALTH & REQUIREMENTS
  ══════════════════════════════════════════ -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div style="background:#0F172A; padding:3rem 2.5rem;">
        <p class="font-montserrat tracking-widest uppercase mb-3" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.2em;">Our Standards</p>
        <h2 class="font-cormorant font-light italic text-white mb-2" style="font-size:2.25rem;">Health &amp; Requirements</h2>
        <div class="gold-rule mb-8" style="max-width:80px; margin-left:0; background:linear-gradient(90deg,#D4AF37,transparent);"></div>
        <p class="font-montserrat text-white/40 mb-8" style="font-size:0.72rem; letter-spacing:0.05em;">The well-being of every guest in our care demands the highest standards of health compliance.</p>
        <div class="grid sm:grid-cols-2 gap-8">
          {[
            { title: 'Vaccination Requirements', body: 'Current Rabies, Bordetella (within 6 months), and DHPP/DA2PP are mandatory for all guests. Records are verified by our veterinary staff prior to arrival.' },
            { title: 'Temperament Assessment', body: 'All new guests complete a complimentary 30-minute pre-arrival assessment conducted by a certified behavioral specialist before their first reservation is confirmed.' },
            { title: 'Health on Arrival', body: 'All guests must arrive free of ectoparasites, not in heat, and free of any contagious condition. Our staff conducts a brief health check for every guest upon arrival.' },
            { title: 'Emergency Protocol', body: 'Dr. Kim is on-property during peak hours and on-call overnight. Owners are notified within minutes of any concern. Response time is guaranteed under 15 minutes.' },
          ].map((item) => (
            <div>
              <p class="font-montserrat tracking-widest uppercase mb-2" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.18em;">{item.title}</p>
              <p class="font-montserrat text-white/55 text-sm font-light leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       THE EXPERIENCE — SPLIT
  ══════════════════════════════════════════ -->
  <section style="background:#0F172A; overflow:hidden; padding:0;">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 items-stretch">
      <div style="min-height:440px; overflow:hidden;">
        <Picture
          src={img('1587300003388')}
          alt="A standard of care your pet deserves"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 50vw"
          formats={['avif','webp']}
          fallbackFormat="webp"
          quality={75}
          loading="lazy"
          decoding="async"
          style="width:100%; height:100%; object-fit:cover; min-height:440px; display:block;"
        />
      </div>
      <div class="p-12 md:p-16 flex flex-col justify-center">
        <p class="font-montserrat tracking-widest uppercase mb-4" style="color:#D4AF37; font-size:0.65rem; letter-spacing:0.2em;">The Experience</p>
        <h2 class="font-cormorant font-light italic text-white leading-tight mb-6" style="font-size:clamp(2rem,4vw,2.8rem);">A Standard of Care<br/>Your Pet Deserves</h2>
        <p class="font-montserrat text-white/55 text-sm leading-relaxed mb-6 font-light">{business.description}</p>
        <p class="font-cormorant italic leading-relaxed mb-8" style="color:#D4AF37; font-size:1.05rem; opacity:0.85;">
          "Every guest receives a personalized care plan, reviewed by our on-call veterinarian, and executed by staff trained to five-star hospitality standards."
        </p>
        <div>
          <a href="#booking" class="btn-gold-outline">Reserve Your Suite</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       6. PRICING — BY APPOINTMENT FRAMING
  ══════════════════════════════════════════ -->
  <section id="pricing" class="py-24 px-4" style="background:#F8F5F0;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-montserrat tracking-widest uppercase mb-3" style="color:#D4AF37; font-size:0.68rem; letter-spacing:0.2em;">Investment in Excellence</p>
        <h2 class="font-cormorant font-light italic text-[#0F172A]" style="font-size:clamp(2.5rem,5vw,3.5rem);">Suite Packages</h2>
        <div class="gold-rule mt-5 mb-6" style="max-width:120px;"></div>
        <p class="font-montserrat text-[#94A3B8] max-w-md mx-auto" style="font-size:0.72rem; letter-spacing:0.04em;">Curated stays for discerning pets and their equally discerning owners.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-10">
        {packages.map((pkg) => (
          <div
            class="flex flex-col"
            style={pkg.featured
              ? 'background:#0F172A; border-top:2px solid #D4AF37; padding:2.5rem 2rem;'
              : 'background:#fff; border-top:2px solid rgba(212,175,55,0.35); padding:2.5rem 2rem; box-shadow:0 1px 8px rgba(0,0,0,0.04);'}
          >
            {pkg.featured && (
              <p class="font-montserrat tracking-widest uppercase mb-4 text-center" style="color:#D4AF37; font-size:0.62rem; letter-spacing:0.2em;">✦ Signature Package ✦</p>
            )}
            <div class="mb-4">
              <h3 class="font-cormorant italic mb-1" style={`font-size:1.6rem; color:${pkg.featured ? '#D4AF37' : '#0F172A'};`}>{pkg.name}</h3>
              <p class="font-montserrat tracking-widest uppercase" style={`font-size:0.62rem; letter-spacing:0.16em; color:${pkg.featured ? 'rgba(255,255,255,0.35)' : '#94A3B8'};`}>{pkg.period}</p>
            </div>
            <div class="font-cormorant mb-2" style={`font-size:3rem; line-height:1; color:${pkg.featured ? '#D4AF37' : '#0F172A'};`}>
              from {pkg.price}
            </div>
            <p class="font-montserrat text-sm mb-5 font-light" style={`color:${pkg.featured ? 'rgba(255,255,255,0.5)' : '#334155'};`}>{pkg.description}</p>
            <ul class="space-y-2 flex-grow mb-8">
              {pkg.features.map((f) => (
                <li class="flex items-start gap-2 font-montserrat text-sm font-light" style={`color:${pkg.featured ? 'rgba(255,255,255,0.65)' : '#334155'};`}>
                  <span style={`color:${pkg.featured ? '#D4AF37' : '#B8860B'}; margin-top:1px; flex-shrink:0;`}>—</span> {f}
                </li>
              ))}
            </ul>
            <a href="#booking" class={pkg.featured ? 'btn-gold-outline text-center' : 'btn-gold-solid text-center'}>
              Request Information
            </a>
          </div>
        ))}
      </div>
      <p class="text-center font-montserrat text-[#94A3B8]" style="font-size:0.65rem; letter-spacing:0.06em;">
        All rates subject to seasonal availability. Please contact us to discuss your pet's specific needs.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       HOW IT WORKS
  ══════════════════════════════════════════ -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
