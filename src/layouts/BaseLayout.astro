---
export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  heroImage?: string;
  variant?: string;
  schemaJson?: string;
}

const { title, description, ogImage, heroImage, variant = '', schemaJson } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://pets.dcrader.dev');
import '../global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    {heroImage && <link rel="preload" as="image" href={heroImage} fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Lato:wght@300;400;700&family=Oswald:wght@400;500;600;700&family=Open+Sans:wght@400;600&family=Fredoka+One&family=Nunito:wght@400;600;700;800&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {schemaJson && <Fragment set:html={`<script type="application/ld+json">${schemaJson}</script>`} />}
    <script src="/template-topheader.js" defer></script>
    <style is:global>
      html { scroll-padding-top: 40px !important; }
      body { padding-top: 36px !important; }
      body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
    </style>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-black focus:px-3 focus:py-2 focus:rounded">Skip to content</a>
    <div id="main">
      <slot />
    </div>
    <div role="contentinfo" style="background:#0a0a0a; color:rgba(255,255,255,0.55); font-size:0.75rem; text-align:center; padding:0.875rem 1rem; font-family:'Inter',system-ui,sans-serif; letter-spacing:0.02em;">
      Built by <a href="https://dcrader.dev" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.8); text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.2);">Donovan Crader · dcrader.dev</a>
    </div>
    <button id="back-to-top" aria-label="Back to top" style="position:fixed;bottom:72px;right:18px;z-index:40;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,0.12);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);color:#fff;font-size:18px;display:none;align-items:center;justify-content:center;cursor:pointer;transition:opacity 0.2s,transform 0.2s;" onmouseenter="this.style.opacity='0.8'" onmouseleave="this.style.opacity='1'">↑</button>
    <script is:inline>
      const btn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (btn) btn.style.display = window.scrollY > 400 ? 'flex' : 'none';
      });
      if (btn) btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    </script>
  <script src="/back-pill.js" defer></script>
  </body>
</html>
