{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "cozyboutique.dcrader.dev"
        }
      ],
      "destination": "/v1-cozy-boutique/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "trailandtails.dcrader.dev"
        }
      ],
      "destination": "/v2-active-outdoor/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "calmcoatgrooming.dcrader.dev"
        }
      ],
      "destination": "/v3-clinical-trust/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "sniffandsnuggle.dcrader.dev"
        }
      ],
      "destination": "/v4-fun-bright/$1"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "thehollowpethotel.dcrader.dev"
        }
      ],
      "destination": "/v5-luxury-resort/$1"
    }
  ]
}
